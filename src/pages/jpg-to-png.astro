---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Why convert JPEG to PNG?',
    a: 'The main reasons are: (1) you need to add transparency — JPEG cannot have a transparent background, PNG can; (2) you want a lossless copy for editing, since PNG can be re-saved without further quality loss unlike JPEG; (3) a platform requires PNG specifically (some design tools and CMS systems prefer PNG for logos and graphics); (4) you want to avoid further JPEG recompression artefacts when editing and re-saving.',
  },
  {
    q: 'Will the PNG file be larger than the JPEG?',
    a: 'Yes, almost always significantly larger. JPEG is a lossy format designed for photographs and achieves very high compression. PNG is lossless — it stores every pixel exactly. A 200 KB JPEG photo might become a 1–3 MB PNG. If file size is a concern and you do not need transparency, keep the JPEG or convert to WebP instead.',
  },
  {
    q: 'Does converting JPEG to PNG improve quality?',
    a: 'No. Any quality loss that occurred when the original JPEG was saved is permanent. Converting to PNG saves the current pixel values losslessly, but it cannot recover information that was discarded during JPEG compression. You will get a larger file that is no better quality than the source JPEG — but it will not degrade further when you re-save it as PNG.',
  },
  {
    q: 'Can I add transparency after converting JPEG to PNG?',
    a: 'This tool converts the JPEG to PNG but does not add or edit transparency. The conversion gives you a PNG with the same opaque image content as the JPEG. To make parts of the image transparent (e.g., remove a white background), you would then open the PNG in an image editor like GIMP, Photoshop, or an online background remover tool.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/jpg-to-png#app`,
      name: `JPG to PNG Converter — ${siteConfig.siteName}`,
      description: 'Convert JPEG images to PNG format online for free. Get a lossless PNG with no quality degradation.',
      url: `${siteConfig.domain}/jpg-to-png`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="JPG to PNG Converter Online — Free"
  description="Convert JPEG images to PNG format online for free. Get a lossless PNG with no quality degradation."
  canonical={`${siteConfig.domain}/jpg-to-png`}
  keywords="jpg to png, jpeg to png converter, convert jpg to png online"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/jpg-to-png" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>JPG to PNG Converter</h1>
        <p class="tool-desc">Convert JPEG images to PNG format online for free. Get a lossless PNG with no quality degradation.</p>
      </header>

      <ConvertTool from="JPG" to="png" />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>Converting JPEG to PNG is useful when you need a lossless copy of a photograph for editing. Because JPEG recompresses the image every time you save, editing a JPEG repeatedly (open, adjust, save, open again, adjust, save) causes progressive quality degradation. By converting to PNG first, you get a lossless format that preserves the exact pixel values no matter how many times you re-save it.</p>
        <p>PNG is also the required format for logos and graphics that will be placed on transparent backgrounds. If you have a product photo in JPEG and need to remove the background and save with transparency, you need PNG — JPEG does not support transparent pixels. Converting to PNG before background removal is the correct workflow.</p>
        <p>Keep in mind that the PNG output will be substantially larger than the JPEG source. For a typical smartphone photo, the PNG may be 5–10 times larger. This is expected and normal. If you need to share or upload the image after editing, re-save it as JPEG (or WebP) when you are done with your edits.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your JPEG image onto the tool.</li>
          <li>PNG is pre-selected as the output format.</li>
          <li>Click "Convert" — the JPEG is decoded and re-encoded as a lossless PNG.</li>
          <li>Download the PNG file and open it in your image editor.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
