---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ResizeTool from '../components/tools/ResizeTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Why do Amazon and Flipkart require square product images?',
    a: 'E-commerce platforms use square images so product thumbnails display consistently in grid layouts without cropping or distortion. Amazon requires the main product image to be at least 500×500 px and recommends 1000×1000 px or larger for zoom functionality. 600×600 px is a widely-used size for secondary images and catalogue uploads where file size is also a concern.',
  },
  {
    q: 'Will resizing stretch my image if it is not square?',
    a: 'Yes, if your original image is not square (1:1 ratio) and the aspect ratio is unlocked, resizing to 600×600 px will stretch it. To avoid this, crop your image to a 1:1 ratio first, centred on your subject, then resize. Alternatively, upload a square crop of your subject directly.',
  },
  {
    q: 'What is the ideal WhatsApp DP size?',
    a: 'WhatsApp displays profile photos (DPs) as circles and accepts images up to 5 MB. It automatically resizes large uploads, but uploading a 600×600 px image gives you full control — the image loads fast and looks sharp when contacts view it full-size.',
  },
  {
    q: 'Can I use this for Facebook or Instagram profile photos?',
    a: 'Yes. Facebook displays profile photos at 170×170 px on desktops but stores them at higher resolution. Instagram profile pictures are shown at 110×110 px. A 600×600 px source gives both platforms enough resolution to display crisply on all screens, including retina displays.',
  },
  {
    q: 'Is 600×600 px accepted for US visa photos?',
    a: 'US visa and passport photos must be 2×2 inches, which at 300 DPI equals 600×600 px. So yes — 600×600 px is the correct pixel dimension for US visa photos. After resizing to 600×600 px here, ensure the file meets any KB limit requirements and print at 300 DPI for physical submission.',
  },
  {
    q: 'Is this free and does it work without uploading to a server?',
    a: 'Yes — completely free, no account required, and 100% private. Your image is resized entirely in your browser using the HTML5 Canvas API. Nothing is uploaded to any server, so you can safely resize sensitive photos like ID pictures and government documents.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/resize-image-to-600x600#app`,
      name: 'Resize Image to 600×600 px Free Online',
      description: 'Resize any image to 600×600 pixels free online. No upload, 100% private. For social media profiles, WhatsApp DP, Amazon product images, and US visa photos.',
      url: `${siteConfig.domain}/resize-image-to-600x600`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Resize Image to 600×600 px Free Online"
  description="Free online tool to resize any image to 600×600 pixels. No upload, 100% private. For WhatsApp DP, social profiles, Amazon product images &amp; US visa photos."
  canonical={`${siteConfig.domain}/resize-image-to-600x600`}
  keywords="resize image to 600x600, 600x600 photo resize, square image resize, resize image square, whatsapp dp size, amazon product image size"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/resize-image-to-600x600" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Resize Image to 600×600 px — Free</h1>
        <p class="tool-desc">Free online tool to resize any image to 600×600 pixels. No upload, 100% private. For WhatsApp DP, social media profiles, Amazon product images, and US visa photos.</p>
      </header>

      <ResizeTool width={600} height={600} lockAspect={false} outputFormat="jpeg" presetLabel="600×600 px (Square)" />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Resize Image to 600×600 Pixels — For Social Media, E-commerce &amp; More</h2>
        <p>600×600 pixels is one of the most widely used square image sizes across the internet. It is large enough to display sharply on all screen types — including retina and high-DPI displays — while remaining small enough that the file is lightweight and loads quickly.</p>
        <p>For social media, 600×600 px works well for WhatsApp DPs, Facebook profile photos, and Instagram profile pictures. Platforms will display these at smaller sizes (170 px on Facebook, 110 px on Instagram) but store the full 600 px version for sharp rendering on high-resolution screens. For profile pictures especially, starting with a 600×600 px source ensures crisp display everywhere.</p>
        <p>For e-commerce, Amazon Seller Central and Flipkart both work with 600×600 px product images for secondary listing photos and variation images. The 1:1 square format is essential for consistent display in product grids where all items must appear at the same size. Amazon also uses this square format for the product thumbnail shown in search results.</p>
        <p>600×600 px at 300 DPI is also the correct size for US visa photos and US passport photos — both require a 2×2 inch square photograph at print resolution. After resizing here, print at 300 DPI for physical submission, or upload directly for online US visa applications (DS-160).</p>

        <h3>How to Resize to 600×600 px</h3>
        <ol>
          <li><strong>Prepare your image.</strong> For best results, start with a square crop — especially for portraits and product photos. If your original image is not square, the resizer will stretch it unless you crop first.</li>
          <li><strong>Upload the image.</strong> Click "Choose File" or drag and drop. The dimensions are pre-set to 600×600 px with the aspect ratio unlocked.</li>
          <li><strong>Select output format.</strong> JPEG for photos (smallest file size), PNG if you need transparency preserved.</li>
          <li><strong>Click "Resize" and download.</strong> The 600×600 px image is ready to use on WhatsApp, upload to Amazon Seller Central, or print for US visa applications.</li>
        </ol>

        <h3>Common Use Cases</h3>
        <p><strong>WhatsApp DP:</strong> Upload a 600×600 px JPEG for a sharp profile picture that looks good when contacts view it full-size. WhatsApp will downsample it for display but keeps the larger version for full-size viewing.</p>
        <p><strong>Amazon &amp; Flipkart product images:</strong> Secondary and variation product images on major Indian and global e-commerce platforms are commonly 600×600 px. Ensures consistent grid display without white space or cropping.</p>
        <p><strong>US visa/passport photo:</strong> The US Department of State requires 2×2 inch photos — 600×600 px at 300 DPI. Print at 300 DPI on 4×6 photo paper and cut to size.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/resize-image-to-passport-size" class="related-card">
            <span class="related-name">Passport Size Photo</span>
            <span class="related-desc">413×531 px / 35×45 mm</span>
          </a>
          <a href="/resize-image-to-200x200" class="related-card">
            <span class="related-name">Resize to 200×200</span>
            <span class="related-desc">Avatars &amp; thumbnails</span>
          </a>
          <a href="/compress-image-to-100kb" class="related-card">
            <span class="related-name">Compress to 100 KB</span>
            <span class="related-desc">Job portals &amp; e-commerce</span>
          </a>
          <a href="/resize-image" class="related-card">
            <span class="related-name">Resize Image</span>
            <span class="related-desc">Any custom pixel dimensions</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
