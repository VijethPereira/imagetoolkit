---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'What is the photo size limit on Naukri.com?',
    a: 'Naukri.com allows profile photos up to 200 KB in JPEG or PNG format. At 150 KB, a professional headshot at 600×800 px looks excellent — sharp, well-detailed, and suitable for a professional profile. Uploading at 150 KB instead of 200 KB also means slightly faster page loads for recruiters viewing your profile.',
  },
  {
    q: 'Which job portals and career sites use a 150 KB photo limit?',
    a: 'TimesJobs.com, Shine.com, and several company-specific ATS (Applicant Tracking System) portals use 150 KB as their photo upload ceiling. Some HR software platforms like Zoho Recruit and Freshteam impose 150 KB limits on candidate profile photos. Many corporate career pages built on SAP SuccessFactors or Workday also use limits in the 100–200 KB range.',
  },
  {
    q: 'What resolution should a professional headshot be at 150 KB?',
    a: 'For a professional job portal headshot, aim for 600×800 px or 800×1000 px at 150 KB. Both fit comfortably within 150 KB and look sharp at the sizes job portals display profile photos. At 600×800 px, a 150 KB JPEG uses a quality setting around 85–90%, which is considered the professional standard for web photography.',
  },
  {
    q: 'How is a 150 KB professional photo different from a 20 KB exam photo?',
    a: 'The difference is enormous. An exam portal photo is typically 200×230 px at 20 KB — the goal is basic face recognition for identity verification. A professional headshot at 600×800 px and 150 KB is crisp enough to show skin texture, individual hair strands, and clothing fabric details. This level of quality is appropriate for job profiles where recruiters spend more time studying your presentation.',
  },
  {
    q: 'Can I compress a PNG professional photo to 150 KB?',
    a: 'Yes — upload your PNG here and set output to JPEG. A professional headshot PNG is often 3–10 MB, so compressing to 150 KB JPEG is a significant reduction. The output will look excellent at 150 KB because JPEG handles continuous-tone photography (skin tones, backgrounds, clothing) very efficiently at quality settings around 85%.',
  },
  {
    q: 'Does compressing to 150 KB affect the image dimensions?',
    a: 'No. This tool only adjusts JPEG quality to reach the target file size — dimensions are preserved exactly. If you need to resize your photo before compressing, use the Resize Image tool first, then return here to compress to 150 KB.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-150kb#app`,
      name: 'Compress Image to 150 KB Online Free',
      description: 'Compress any JPG, PNG, or WebP image to under 150 KB online. Free, no upload, 100% private. For Naukri, TimesJobs, Shine, job portals, and professional profiles.',
      url: `${siteConfig.domain}/compress-image-to-150kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 150 KB — Free, No Upload"
  description="Free tool to compress any image to under 150 KB. 100% private, no upload. For Naukri.com, TimesJobs, Shine, ATS portals, and professional profile photos. JPG, PNG, WebP."
  canonical={`${siteConfig.domain}/compress-image-to-150kb`}
  keywords="compress image to 150kb, reduce to 150kb, naukri photo size, job portal photo compress, compress image 150kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-150kb" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 150 KB Online</h1>
        <p class="tool-desc">Free tool to compress any photo to under 150 KB. 100% private, no upload. Perfect for job portal profile photos — Naukri, TimesJobs, Shine, and ATS upload requirements.</p>
      </header>

      <CompressTool targetKB={150} />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Compress Image to 150 KB — Job Portals &amp; Professional Profile Photos</h2>
        <p>150 KB is the practical sweet spot for professional profile photos on Indian and international job portals. Naukri.com — India's largest job portal — accepts photos up to 200 KB, and 150 KB gives you a comfortably-sized file with excellent quality. TimesJobs, Shine.com, and Apna.co follow similar limits. Many company career portals built on HR software platforms like Zoho Recruit, Freshteam, SAP SuccessFactors, and Oracle HCM impose upload limits between 100 KB and 200 KB.</p>
        <p>Unlike exam portal photos (where the only goal is identity verification at 20 KB), a professional profile headshot needs to make a good first impression. At 150 KB and 600×800 px, a JPEG photo uses a quality setting around 85–90% — the standard professional range for web photography. Individual hair strands, eyebrow details, skin texture, and fabric patterns all render crisply at this size.</p>
        <p>This tool runs entirely in your browser. No upload, no account, no watermark. Your professional headshot is processed locally and stays private.</p>

        <h3>Professional Headshot Best Practices for Job Portals</h3>
        <p>The technical quality of the image matters only as much as the quality of the original photograph. A perfectly compressed 150 KB photo of a poorly-lit selfie will not look professional, whereas a studio headshot compressed to 150 KB will look excellent. Some guidelines:</p>
        <ol>
          <li>Use natural or studio lighting — avoid harsh shadows across the face.</li>
          <li>Wear formal or smart-casual attire appropriate for your industry.</li>
          <li>Use a neutral, plain background — white, grey, or light blue work best. Avoid cluttered or distracting backgrounds.</li>
          <li>Frame the shot from chest to head, with your face centred and occupying roughly 60% of the frame height.</li>
          <li>Resize to 600×800 px or 800×1000 px using the <a href="/resize-image">Resize Image tool</a> before compressing.</li>
          <li>Upload here, compress to 150 KB with JPEG output, download, and upload to the job portal.</li>
        </ol>

        <h3>150 KB vs 200 KB — Is There a Visible Difference?</h3>
        <p>At 600×800 px (480,000 pixels), the difference between a 150 KB JPEG (around quality 87%) and a 200 KB JPEG (around quality 91%) is visible only under close inspection or when zoomed in. For the thumbnail sizes that job portals display profile photos, the two are visually identical. Compressing to 150 KB instead of allowing the file to go up to 200 KB is primarily about respecting upload limits and ensuring your file is accepted without issues.</p>
        <p>For smaller file size needs such as exam portals, see <a href="/compress-image-to-100kb">Compress to 100 KB</a> or <a href="/compress-image-to-200kb">Compress to 200 KB</a>. For JPEG-specific compression without a fixed target, use <a href="/compress-jpg">Compress JPG</a> with the quality slider.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-100kb" class="related-card">
            <span class="related-name">Compress to 100 KB</span>
            <span class="related-desc">Job portals &amp; general use</span>
          </a>
          <a href="/compress-image-to-200kb" class="related-card">
            <span class="related-name">Compress to 200 KB</span>
            <span class="related-desc">Higher quality web photos</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Custom quality &amp; size target</span>
          </a>
          <a href="/compress-jpg" class="related-card">
            <span class="related-name">Compress JPG</span>
            <span class="related-desc">JPEG quality slider control</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
