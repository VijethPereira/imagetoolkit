---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig, { toolCategories } from '../site.config.ts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteConfig.domain}/#website`,
      url: siteConfig.domain,
      name: siteConfig.siteName,
      description: siteConfig.tagline,
    },
    {
      '@type': 'Organization',
      '@id': `${siteConfig.domain}/#org`,
      name: siteConfig.siteName,
      url: siteConfig.domain,
    },
    {
      '@type': 'ItemList',
      name: 'Image Tools',
      itemListElement: siteConfig.tools.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.name,
        url: `${siteConfig.domain}${t.href}`,
      })),
    },
  ],
};
---

<Layout
  title={siteConfig.siteName}
  description={siteConfig.tagline}
  canonical={siteConfig.domain}
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/" />
  <main>
    <section class="hero">
      <div class="container">
        <h1>{siteConfig.siteName}</h1>
        <p class="tagline">{siteConfig.tagline}</p>
        <div class="privacy-badge">
          🔒 100% private — images never leave your device
        </div>
      </div>
    </section>

    {toolCategories.map((cat) => (
      <section class="category-section">
        <div class="container">
          <h2 class="cat-label">{cat.label}</h2>
          <div class="tool-grid">
            {cat.tools.map((tool) => (
              <a href={tool.href} class="tool-card">
                <div class="card-header">
                  <span class="card-name">{tool.name}</span>
                  {tool.badge && <span class="card-badge">{tool.badge}</span>}
                </div>
                <p class="card-desc">{tool.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <section class="seo-section">
      <div class="container">
        <h2>Free Image Tools — No Upload Required</h2>
        <p>All tools on Image Tools run entirely in your browser using the Canvas API. Your images are never sent to any server — they stay on your device throughout the entire process. This makes our tools fast, private, and free to use without any account or registration.</p>
        <h3>Why use browser-based image tools?</h3>
        <ul>
          <li><strong>Privacy</strong> — your photos and documents never leave your device.</li>
          <li><strong>Speed</strong> — no upload/download waiting time for large files.</li>
          <li><strong>Free forever</strong> — no subscriptions, no credits, no limits.</li>
          <li><strong>Works offline</strong> — once the page loads, no internet needed.</li>
        </ul>
        <h3>Popular use cases in India</h3>
        <p>Our most-used tools help with government exam applications (SSC, UPSC, NTA, IBPS), college admissions, visa applications, and online job portals — all of which require photos and signatures in specific sizes and file sizes.</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--site-border);
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--site-text);
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  .tagline {
    font-size: 1.125rem;
    color: var(--site-text-muted);
    margin: 0 0 1.25rem;
    max-width: 52ch;
  }

  .privacy-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--site-accent);
    background: color-mix(in srgb, var(--site-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--site-accent) 25%, transparent);
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
  }

  .category-section {
    padding: 2.5rem 0 0.5rem;
  }

  .category-section:last-of-type {
    padding-bottom: 2rem;
  }

  .cat-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--site-accent);
    margin: 0 0 1rem;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.875rem;
  }

  .tool-card {
    display: block;
    padding: 1.125rem 1.25rem;
    border: 1px solid var(--site-border);
    border-radius: 10px;
    background: var(--site-bg-card);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tool-card:hover {
    border-color: var(--site-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--site-accent) 12%, transparent);
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .card-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--site-text);
  }

  .card-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--site-accent) 12%, transparent);
    color: var(--site-accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-desc {
    font-size: 0.8125rem;
    color: var(--site-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .seo-section {
    padding: 3rem 0 4rem;
    border-top: 1px solid var(--site-border);
    margin-top: 1rem;
  }

  .seo-section h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--site-text);
    margin: 0 0 0.75rem;
  }

  .seo-section h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--site-text);
    margin: 1.75rem 0 0.5rem;
  }

  .seo-section p {
    color: var(--site-text-muted);
    margin: 0 0 1rem;
    max-width: 72ch;
  }

  .seo-section ul {
    color: var(--site-text-muted);
    padding-left: 1.5rem;
    max-width: 64ch;
    margin: 0;
  }

  .seo-section li {
    margin-bottom: 0.375rem;
  }

  .container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
</style>
