---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Which exams require a photo under 20 KB?',
    a: 'SSC CGL, SSC CHSL, SSC CPO, SSC MTS, and IBPS PO/Clerk/SO typically require the photograph to be under 20 KB in JPEG format. RRB NTPC and some state PSC exams also have this limit. Always check the official notification for the current exam cycle, as requirements can change.',
  },
  {
    q: 'Will image quality be acceptable for exam applications?',
    a: 'Yes. Exam portals only need to verify your identity from the photo — they do not require print-quality images. A 20 KB JPEG at 200×230 px is perfectly adequate for this purpose and is accepted by SSC and IBPS portals.',
  },
  {
    q: 'Why does my image look blurry after compression to 20 KB?',
    a: 'If the original photo is very large (e.g., 5 MB from a smartphone), compressing it to 20 KB requires a significant quality reduction. For better results, first resize your photo to around 200×230 pixels using the Resize tool, then compress. Smaller dimensions require far less compression to hit the 20 KB target.',
  },
  {
    q: 'Can I compress a PNG image to 20 KB?',
    a: 'PNG files are much harder to compress to very small sizes because PNG uses lossless compression. For exam uploads, switch the output format to JPEG — JPEGs can easily be compressed to 20 KB while keeping the photo recognisable. Most exam portals explicitly require JPEG anyway.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-20kb#app`,
      name: `Compress Image to 20 KB — ${siteConfig.siteName}`,
      description: 'Compress any JPG, PNG, or WebP image to under 20 KB online. No software needed. Perfect for SSC CGL, IBPS, and govt exam photo uploads.',
      url: `${siteConfig.domain}/compress-image-to-20kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 20 KB Online — Free"
  description="Compress any JPG, PNG, or WebP image to under 20 KB online. No software needed. Perfect for SSC CGL, IBPS, and govt exam photo uploads."
  canonical={`${siteConfig.domain}/compress-image-to-20kb`}
  keywords="compress image to 20kb, reduce image size to 20kb, compress photo to 20kb for ssc"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-20kb" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 20 KB</h1>
        <p class="tool-desc">Compress any JPG, PNG, or WebP image to under 20 KB online. No software needed. Perfect for SSC CGL, IBPS, and govt exam photo uploads.</p>
      </header>

      <CompressTool targetKB={20} />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>20 KB is the standard maximum photograph size for most Staff Selection Commission (SSC) exams — including SSC CGL, SSC CHSL, SSC CPO, and SSC MTS. IBPS PO, IBPS Clerk, and RRB NTPC applications also commonly require your photograph to be under 20 KB in JPEG format. Failing to meet this requirement will cause the portal to reject your photo upload.</p>
        <p>This tool automatically targets 20 KB by progressively reducing JPEG quality until the output falls under the limit. Because it works entirely in your browser, your photo is never uploaded to any server — making it both fast and completely private.</p>
        <p>For best results, start with a clear passport-size photograph (200×230 px or similar). Very large photos from smartphones may look slightly soft at 20 KB because the compression ratio needed is extreme. The tip below explains how to avoid this.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your photo onto the tool.</li>
          <li>The target is pre-set to 20 KB — no adjustment needed.</li>
          <li>Make sure the output format is set to JPEG for the smallest file size.</li>
          <li>Click "Compress" — the tool will automatically find the right quality level.</li>
          <li>Check the result and download when ready.</li>
          <li>Tip: If the photo looks too blurry, first <a href="/resize-image-to-passport-size">resize it to passport dimensions</a>, then compress.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
