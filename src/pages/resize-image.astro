---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ResizeTool from '../components/tools/ResizeTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'How do I resize an image to a specific pixel size online for free?',
    a: 'Drop your image on this tool, enter your target width and height in pixels, and click "Resize". The tool processes everything in your browser — no upload needed. For government exam portals that specify exact dimensions (e.g., 200×230 px), unlock the aspect ratio and enter both values independently.',
  },
  {
    q: 'What is the difference between resizing and compressing an image?',
    a: 'Resizing changes the pixel dimensions (width × height) of an image. Compression reduces file size (bytes) without changing the dimensions. Both reduce file size, but for strict KB limits on exam portals, you should do both: resize to the required pixel dimensions first, then use the compress tool to hit the required KB target.',
  },
  {
    q: 'Will resizing reduce image file size?',
    a: 'Yes. Reducing pixel dimensions always reduces file size because there is less image data to store. A 4000×3000 px photo resized to 400×300 px can be 90% smaller even before additional compression. The file size reduction from resizing alone is often enough for web use, though for strict KB limits a separate compression step is usually also needed.',
  },
  {
    q: 'Should I maintain aspect ratio when resizing?',
    a: 'For general use (web images, social media, profile photos), keep the aspect ratio locked — it prevents stretching or squashing. For applications that require exact pixel dimensions (government forms, e-commerce platforms, passport photos), unlock the aspect ratio and enter both dimensions exactly. You may need to crop the image first if the ratio difference is large.',
  },
  {
    q: 'What output format should I choose?',
    a: 'JPEG for photographs — smallest file size, widest compatibility with portals and email clients. PNG for logos, screenshots, and images with transparent backgrounds. WebP for web images where all viewers use modern browsers — 25–34% smaller than JPEG at the same quality.',
  },
  {
    q: 'How do I convert centimetres to pixels for a government form?',
    a: 'Multiply the centimetre measurement by the DPI (dots per inch). For print (300 DPI): 1 cm × 300 ÷ 2.54 ≈ 118 px. So a 3.5 cm × 4.5 cm photo at 300 DPI is 413×531 px. For screen displays (96 DPI): 1 cm × 96 ÷ 2.54 ≈ 38 px. Government exam portals almost always specify dimensions in pixels directly, so just enter those values.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/resize-image#app`,
      name: 'Image Resizer Online Free',
      description: 'Resize any image to custom pixel dimensions free online. No upload, 100% private. Supports JPG, PNG, WebP. Set any width and height.',
      url: `${siteConfig.domain}/resize-image`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Image Resizer Online — Free, No Upload"
  description="Free online image resizer — change width &amp; height in pixels. No upload, 100% private. Supports JPG, PNG, WebP. Any custom dimensions."
  canonical={`${siteConfig.domain}/resize-image`}
  keywords="resize image, image resizer online, change image size, resize image free, reduce image dimensions, resize photo online, resize image to custom size"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/resize-image" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Image Resizer Online — Free</h1>
        <p class="tool-desc">Resize any image to custom pixel dimensions free online. No upload, 100% private. Set any width and height — supports JPG, PNG, and WebP.</p>
      </header>

      <ResizeTool />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Free Online Image Resizer — Change Pixel Dimensions Instantly</h2>
        <p>Image resizing changes the pixel width and height of an image. This is fundamentally different from compression — resizing physically reduces or enlarges the image canvas itself, while compression reduces file size without changing dimensions. When you need to meet a specific pixel requirement (e.g., "photo must be exactly 200×230 px" on an exam portal), resizing is the right tool. For KB limits, combine resizing with compression.</p>
        <p>This free online image resizer works entirely in your browser. Your photo is drawn onto an off-screen HTML5 Canvas at the target dimensions and re-encoded in your chosen format. Nothing is uploaded — processing is instant and completely private, making it safe for passport photos, ID images, and sensitive documents.</p>

        <h3>How to Resize an Image Online</h3>
        <ol>
          <li><strong>Upload your image.</strong> Click "Choose File" or drag and drop your JPG, PNG, or WebP image onto the tool.</li>
          <li><strong>Enter dimensions.</strong> Type your target width and/or height in pixels. Use the "Lock aspect ratio" toggle to resize proportionally (prevents distortion), or unlock it to set both dimensions independently for exact pixel requirements.</li>
          <li><strong>Choose format.</strong> Select JPEG for photos, PNG for graphics with transparency, or WebP for web-optimised images.</li>
          <li><strong>Download.</strong> Click "Resize" and download the resized image. Review the file size — if it still exceeds a KB limit, use the compress tool next.</li>
        </ol>

        <h3>Supported Image Formats</h3>
        <p><strong>JPEG (JPG)</strong> — Best for photographs. The resized output will be a JPEG, giving you the smallest file size for photographic content. Required by SSC, IBPS, UPSC, and most Indian government portals.</p>
        <p><strong>PNG</strong> — Lossless format for logos and graphics. Keeps the image pixel-perfect. Useful if you need to preserve a transparent background (though you may also want to crop to fit first).</p>
        <p><strong>WebP</strong> — Google's modern web format. Produces 25–34% smaller files than JPEG at the same visual quality. Ideal for resizing photos for web pages and mobile apps.</p>

        <h3>Common Use Cases</h3>
        <p><strong>Government exam photo uploads:</strong> SSC, IBPS, UPSC, RRB, and NTA portals specify exact pixel dimensions for photos and signatures. Enter the required dimensions (e.g., 200×230 px for SSC photo, 413×531 px for passport size), resize, then compress to the required KB limit.</p>
        <p><strong>Social media profile pictures:</strong> Facebook displays profile photos at 170×170 px. Instagram shows profile circles at 110×110 px. WhatsApp DPs are 640×640 px internally. Resize to these dimensions for optimal display.</p>
        <p><strong>E-commerce product images:</strong> Amazon and Flipkart require product images at specific aspect ratios and minimum resolutions. Resize and compress before uploading to ensure your images meet marketplace requirements and load quickly.</p>
        <p><strong>Web page optimisation:</strong> Serving images at their display size (rather than large originals scaled down by CSS) is one of the most impactful web performance improvements. Resize images to their exact display dimensions before uploading to your CMS.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/resize-image-to-passport-size" class="related-card">
            <span class="related-name">Passport Size Photo</span>
            <span class="related-desc">413×531 px / 35×45 mm</span>
          </a>
          <a href="/signature-resizer-for-ssc" class="related-card">
            <span class="related-name">SSC Signature Resize</span>
            <span class="related-desc">276×118 px, under 12 KB</span>
          </a>
          <a href="/resize-image-to-600x600" class="related-card">
            <span class="related-name">Resize to 600×600</span>
            <span class="related-desc">Social profiles &amp; e-commerce</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Reduce file size in KB</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
