---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'How do I compress an image to 100 KB without losing quality?',
    a: 'This tool does it automatically — it binary-searches for the highest JPEG quality that keeps the output under 100 KB. At 100 KB, most portrait photos at 400×500 px can be encoded at JPEG quality 80–90%, producing sharp, attractive results with no visible compression artefacts.',
  },
  {
    q: 'What is the 100 KB image limit used for?',
    a: 'The 100 KB limit appears on job application portals (Naukri, LinkedIn company portals, IRCTC), company HR systems, e-commerce seller dashboards, several Indian railway and police recruitment portals, and university registration systems. Profile photos on many platforms are also recommended to be under 100 KB for fast page loading.',
  },
  {
    q: 'What quality can I expect at 100 KB?',
    a: 'At 100 KB, even a 600×800 px portrait photograph compresses to JPEG quality 80–90%, which looks excellent — sharp details, accurate colours, and no visible artefacts. This is a comfortable target that preserves good visual quality for both identification and display purposes.',
  },
  {
    q: 'Can I compress a PNG to 100 KB?',
    a: 'Yes. For photographs, switch the output format to JPEG for best results — PNG uses lossless compression and may be much larger than 100 KB even after compression. For logos or graphics with transparency, WebP supports alpha channels and compresses far better than PNG at this size target.',
  },
  {
    q: 'My image is 102 KB — will it be rejected by the portal?',
    a: 'Most portals enforce the file size limit strictly and will reject anything over the stated maximum, even by 1–2 KB. Always aim for a safe margin: if the limit is 100 KB, target 95 KB or less. This tool targets exactly 100 KB but file size calculation methods can vary, so download and check the actual file size before uploading.',
  },
  {
    q: 'Is this tool free and does it work without uploading my image?',
    a: 'Yes. It is completely free with no account required. All processing happens in your browser using the Canvas API — your image is never uploaded to any server. This makes it safe for sensitive images like ID photos and professional headshots.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-100kb#app`,
      name: 'Image Compressor to 100 KB Online Free',
      description: 'Compress any image to under 100 KB free online. No upload, 100% private. Perfect for job portals, e-commerce, and general web use.',
      url: `${siteConfig.domain}/compress-image-to-100kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Image Compressor to 100 KB — Free Online"
  description="Compress any image to under 100 KB free. No upload, 100% private. Great for job portals, e-commerce product images & general web use."
  canonical={`${siteConfig.domain}/compress-image-to-100kb`}
  keywords="compress image to 100kb, image compressor to 100kb, reduce image size to 100kb, compress jpg to 100kb, compress photo 100kb, compress jpeg to 100kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-100kb" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 100 KB Online</h1>
        <p class="tool-desc">Free image compressor to 100 KB. No upload, 100% private. Perfect for job portals, e-commerce product images, and general web use. Supports JPG, PNG, WebP.</p>
      </header>

      <CompressTool targetKB={100} />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Compress Image to 100 KB — For Job Portals &amp; E-commerce</h2>
        <p>The 100 KB limit is one of the most common file size restrictions on job portals, HR management systems, and e-commerce platforms. Naukri, Monster, and most company career portals require profile or application photos under 100 KB. Indian Railways (IRCTC) passenger photo uploads, state police and paramilitary recruitment portals, and several private company job application forms use this same limit.</p>
        <p>At 100 KB, JPEG compression can maintain very high visual quality for portrait photographs — typically 80–90% quality for a 400×500 px image. The result looks sharp, has accurate colours, and shows no visible compression artefacts. This is a comfortable target compared to the more challenging 20 KB or 50 KB limits used by stricter government exam portals.</p>
        <p>This free online image compressor handles the entire process automatically. Drop your image in, and the tool binary-searches for the highest quality setting that produces an output under 100 KB. Your image is never uploaded to a server — processing happens entirely on your device in milliseconds.</p>

        <h3>How to Compress a Photo to 100 KB</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your image. Accepts JPG, PNG, and WebP.</li>
          <li>The 100 KB target is pre-set — no manual adjustment needed.</li>
          <li>Select JPEG output for photographs; WebP for web graphics or images with transparency.</li>
          <li>Click "Compress". The tool finds the optimal quality automatically, usually in under a second.</li>
          <li>Review the before/after comparison and download the compressed image.</li>
        </ol>

        <h3>Common Use Cases for a 100 KB Image Limit</h3>
        <p><strong>Job applications:</strong> Naukri, LinkedIn company portals, and most corporate HR systems require profile or application photos under 100 KB. A professional headshot compressed to 100 KB looks sharp and loads quickly on employer dashboards.</p>
        <p><strong>E-commerce product images:</strong> Faster-loading product pages improve conversion rates and are favoured by Amazon's and Flipkart's search ranking algorithms. Compressing catalogue images to 100 KB or less (or better, converting to WebP) directly impacts your store's performance metrics.</p>
        <p><strong>Website uploads:</strong> Oversized images are the most common cause of slow Core Web Vitals scores. A 100 KB cap on any single image ensures your pages load quickly on mobile connections and passes Google's PageSpeed recommendations.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-50kb" class="related-card">
            <span class="related-name">Compress to 50 KB</span>
            <span class="related-desc">UPSC, NTA portals</span>
          </a>
          <a href="/compress-image-to-200kb" class="related-card">
            <span class="related-name">Compress to 200 KB</span>
            <span class="related-desc">Social media &amp; job portals</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Quality slider compression</span>
          </a>
          <a href="/resize-image" class="related-card">
            <span class="related-name">Resize Image</span>
            <span class="related-desc">Change pixel dimensions</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
