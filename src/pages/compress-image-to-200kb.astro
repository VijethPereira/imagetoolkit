---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'When is a 200 KB image limit used?',
    a: 'The 200 KB limit is common for job application forms, CV photo uploads, social media profile pictures, and some college or university admission portals. Several Indian state government job portals and private company HR systems also use 200 KB as the maximum photograph size.',
  },
  {
    q: 'What image quality can I expect at 200 KB?',
    a: 'At 200 KB, even high-resolution photographs can be compressed with minimal visible quality loss. A 600×800 px portrait compressed to 200 KB JPEG at around 85% quality looks excellent — sharp details, accurate colours, and no visible compression artefacts.',
  },
  {
    q: 'Is 200 KB enough for a LinkedIn profile photo?',
    a: 'Yes. LinkedIn recommends a profile photo between 400×400 and 7680×4320 pixels with a file size under 8 MB, so 200 KB is more than fine. However, the platform will resize and re-compress images anyway, so any photo under a few MB will work. Compressing to 200 KB before uploading just makes the upload faster.',
  },
  {
    q: 'Can I compress a PNG to under 200 KB?',
    a: 'For photographs, yes — convert to JPEG and target 200 KB. For transparent images (logos, icons), PNG is usually required and may already be under 200 KB at moderate resolution. If your PNG logo is larger, consider converting to WebP which supports transparency and compresses much better than PNG.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-200kb#app`,
      name: `Compress Image to 200 KB — ${siteConfig.siteName}`,
      description: 'Compress image to under 200 KB online free. Perfect for job applications, social media, and form uploads.',
      url: `${siteConfig.domain}/compress-image-to-200kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 200 KB Online — Free"
  description="Compress image to under 200 KB online free. Perfect for job applications, social media, and form uploads."
  canonical={`${siteConfig.domain}/compress-image-to-200kb`}
  keywords="compress image to 200kb, reduce image size 200kb, image compressor 200kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-200kb" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 200 KB</h1>
        <p class="tool-desc">Compress image to under 200 KB online free. Perfect for job applications, social media, and form uploads.</p>
      </header>

      <CompressTool targetKB={200} />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>200 KB is a generous but commonly enforced limit on job application portals, company HR onboarding systems, and social media platforms. Unlike the stricter 20 KB or 50 KB limits used by government exam portals, a 200 KB target allows for very high visual quality — most photographs compressed to 200 KB look indistinguishable from the original to the human eye.</p>
        <p>Job seekers frequently need to upload passport-size or professional headshot photos with a 200 KB limit when applying through Naukri, LinkedIn, or company career portals. College admission forms and professional certification registration platforms also commonly use this threshold. Even at 200 KB, modern smartphones produce photos of 3–8 MB that need to be compressed before uploading.</p>
        <p>For social media profile photos, compressing before upload prevents the platform from applying its own aggressive re-compression, which often introduces colour shifts and softness. Uploading a well-compressed image gives you more control over the final appearance.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your image onto the tool.</li>
          <li>The target is pre-set to 200 KB — no adjustment needed.</li>
          <li>Select JPEG output for photographs; WebP for web graphics.</li>
          <li>Click "Compress" — the tool automatically finds the best quality setting.</li>
          <li>Download the result when you are satisfied.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
