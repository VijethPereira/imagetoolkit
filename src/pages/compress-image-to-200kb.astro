---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'When is a 200 KB image limit used?',
    a: 'The 200 KB limit is common for job application forms on corporate HR portals, CV photo uploads, social media profile pictures, and many college or university admission portals. Several Indian state government job sites and private sector company systems also use 200 KB as the maximum photograph size.',
  },
  {
    q: 'What image quality can I expect at 200 KB?',
    a: 'Excellent. At 200 KB, even high-resolution photographs compress with minimal visible quality loss. A 600×800 px portrait at 200 KB JPEG around 85–90% quality looks sharp — detailed, accurate colours, and no visible compression artefacts. This target is comfortable for nearly any photo.',
  },
  {
    q: 'Is 200 KB enough for a LinkedIn profile photo?',
    a: 'Yes. LinkedIn accepts profile photos up to 8 MB and recommends at least 400×400 px. A 200 KB JPEG is more than adequate — it loads quickly, renders sharply on all devices, and passes LinkedIn\'s upload requirements easily.',
  },
  {
    q: 'Can I compress a PNG to under 200 KB?',
    a: 'For photographs, yes — convert to JPEG and target 200 KB. For logos or images with transparency, use WebP (which supports alpha channels and compresses far better than PNG). If the file is a transparent PNG logo under 200 KB already, no conversion is needed.',
  },
  {
    q: 'How do I reduce image size for WhatsApp or Instagram?',
    a: 'Drop your image here and compress to 200 KB. WhatsApp and Instagram will still apply their own re-compression, but uploading a pre-compressed image gives you more control over the final result. For best Instagram quality, use a 1080×1350 px image compressed under 500 KB.',
  },
  {
    q: 'Is my photo private when I use this tool?',
    a: 'Yes — completely. This tool runs entirely in your browser. Your image is never uploaded to any server, never transmitted over the internet, and never stored outside your device. It is 100% private and free to use.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-200kb#app`,
      name: 'Compress Image to 200 KB Online Free',
      description: 'Compress any image to under 200 KB free. No upload, 100% private. Perfect for job portals, LinkedIn photos, and social media uploads.',
      url: `${siteConfig.domain}/compress-image-to-200kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 200 KB Free Online"
  description="Compress any image to under 200 KB free. 100% private, no upload. Perfect for job portals, LinkedIn photos, social media &amp; form uploads."
  canonical={`${siteConfig.domain}/compress-image-to-200kb`}
  keywords="compress image to 200kb, image compressor 200kb, reduce image size 200kb, compress photo to 200kb, compress jpg to 200kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-200kb" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 200 KB Online</h1>
        <p class="tool-desc">Free online tool to compress any image to under 200 KB. 100% private, no upload. Ideal for job portals, LinkedIn headshots, and social media profile pictures.</p>
      </header>

      <CompressTool targetKB={200} />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Compress Image to 200 KB — For Job Applications &amp; Social Media</h2>
        <p>200 KB is a generous but commonly enforced limit on job application portals, company HR onboarding systems, and social platforms. Unlike the stricter 20 KB or 50 KB limits used by government exam portals, a 200 KB target allows for very high visual quality — most photographs compressed to 200 KB look indistinguishable from the original to the human eye.</p>
        <p>Job seekers frequently encounter this limit when uploading a professional headshot or passport-size photo to Naukri, LinkedIn, or a company's career portal. College admission forms and professional certification registration platforms also commonly use 200 KB as the ceiling. Even at 200 KB, modern smartphone photos (3–8 MB) need to be compressed before uploading.</p>
        <p>For social media profile photos, compressing before upload prevents the platform from applying its own aggressive re-compression algorithm — which often introduces colour shifts and softness. Uploading a well-compressed image gives you more control over the final appearance on screen.</p>

        <h3>How to Compress a Photo to 200 KB</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your image. Accepts JPG, PNG, and WebP.</li>
          <li>The 200 KB target is pre-set — no adjustment needed.</li>
          <li>Select JPEG output for photographs; WebP for web graphics.</li>
          <li>Click "Compress" — the tool automatically finds the best quality setting.</li>
          <li>Download the compressed image when you are satisfied with the result.</li>
        </ol>

        <h3>Why Compress Images for Social Media Before Uploading?</h3>
        <p>LinkedIn, Facebook, Instagram, and Twitter all apply their own compression algorithms to uploaded images. If your source photo is 4 MB, the platform may reduce it to under 200 KB using its own compression, which can introduce visible banding, colour inaccuracy, and edge artefacts. By pre-compressing to 200 KB yourself using this tool, you control the compression settings and the output looks better than what the platform would produce automatically.</p>
        <p>For LinkedIn headshots specifically, a 600×600 px JPEG at 200 KB quality looks crisp on profile pages and in search results. For Instagram profile pictures, a 320×320 px JPEG under 200 KB renders sharply in the circular crop Instagram applies.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-100kb" class="related-card">
            <span class="related-name">Compress to 100 KB</span>
            <span class="related-desc">Job portals &amp; e-commerce</span>
          </a>
          <a href="/compress-image-to-50kb" class="related-card">
            <span class="related-name">Compress to 50 KB</span>
            <span class="related-desc">UPSC &amp; NTA portals</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Quality slider compression</span>
          </a>
          <a href="/jpg-to-webp" class="related-card">
            <span class="related-name">JPG to WebP</span>
            <span class="related-desc">Smaller web images</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
