---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ResizeTool from '../components/tools/ResizeTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'What is the SSC signature size in pixels?',
    a: 'SSC requires the scanned signature image to be exactly 276×118 pixels (width × height) in JPEG format with a file size between 1 KB and 12 KB. This applies to SSC CGL, SSC CHSL, SSC CPO, SSC MTS, SSC GD, and all other SSC examinations.',
  },
  {
    q: 'What should the signature background be?',
    a: 'The signature must be done in black or dark blue ink on plain white paper. After scanning or photographing, the background should be white. Do not use lined or coloured paper. The signature should be clearly visible against the white background with no stray marks.',
  },
  {
    q: 'My signature image is bigger than 12 KB after resizing — what should I do?',
    a: 'After resizing to 276×118 px, use the Compress tool to bring the file under 12 KB. A 276×118 px JPEG compressed to around 60–70% quality typically falls between 4–10 KB, which is well within the SSC limit. Visit the compress-image-to-20kb page and compress your resized signature.',
  },
  {
    q: 'Does SSC accept PNG signatures?',
    a: 'No. SSC explicitly requires JPEG (JPG) format for the signature upload. PNG files will be rejected by the portal. This tool is pre-set to output JPEG, so you do not need to change anything.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/signature-resizer-for-ssc#app`,
      name: `SSC Signature Resizer — ${siteConfig.siteName}`,
      description: 'Resize signature image to SSC exam specifications: 276×118 pixels, JPEG, under 12 KB. Works for SSC CGL, CHSL, CPO, MTS, and all SSC exams.',
      url: `${siteConfig.domain}/signature-resizer-for-ssc`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="SSC Signature Resizer Online — 276×118 px, Max 12 KB"
  description="Resize signature image to SSC exam specifications: 276×118 pixels, JPEG, under 12 KB. Works for SSC CGL, CHSL, CPO, MTS, and all SSC exams."
  canonical={`${siteConfig.domain}/signature-resizer-for-ssc`}
  keywords="ssc signature resize, signature resizer for ssc, ssc signature size, signature 276x118"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/signature-resizer-for-ssc" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>SSC Signature Resizer</h1>
        <p class="tool-desc">Resize signature image to SSC exam specifications: 276×118 pixels, JPEG, under 12 KB. Works for SSC CGL, CHSL, CPO, MTS, and all SSC exams.</p>
      </header>

      <ResizeTool width={276} height={118} lockAspect={false} outputFormat="jpeg" presetLabel="SSC Signature (276×118 px)" />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>The Staff Selection Commission requires candidates to upload their scanned signature at exactly 276×118 pixels in JPEG format with a maximum file size of 12 KB. This specification applies to all SSC examinations: SSC CGL (Combined Graduate Level), SSC CHSL (Combined Higher Secondary Level), SSC CPO (Central Police Organisations), SSC MTS (Multi-Tasking Staff), and SSC GD Constable. Getting the signature dimensions wrong is one of the most common reasons for application rejection.</p>
        <p>Common mistakes candidates make with the SSC signature upload: scanning at too low a resolution (which makes the signature illegible), signing on lined or coloured paper (which is rejected), uploading in PNG format (only JPEG is accepted), and having a file that is either too small (under 1 KB) or too large (over 12 KB). This tool addresses the size and format requirements automatically.</p>
        <p>After resizing to 276×118 px with this tool, check the file size. If it is over 12 KB, <a href="/compress-image-to-20kb">use the image compressor</a> to reduce it further. The compressed and resized JPEG should be between 4–10 KB for a typical clean signature scan.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Sign your name in black or dark blue ink on white A4 paper.</li>
          <li>Photograph or scan the signature — a smartphone photo works if the lighting is good.</li>
          <li>Upload the signature image using "Choose File" or drag and drop.</li>
          <li>Dimensions are pre-set to 276×118 px and format to JPEG.</li>
          <li>Click "Resize" and download the result.</li>
          <li>Check the file size of the downloaded image. If it exceeds 12 KB, <a href="/compress-image-to-20kb">compress it</a> before uploading to the SSC portal.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
