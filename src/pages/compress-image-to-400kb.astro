---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Why does LinkedIn recommend profile photos under 400 KB?',
    a: 'LinkedIn accepts photos up to 8 MB but recommends under 400 KB for optimal page performance. LinkedIn profile pages load multiple elements simultaneously — your photo, cover image, posts, and connections. A 400 KB profile photo loads roughly 20x faster than an 8 MB photo. Since recruiters view dozens of profiles per session, fast-loading pages improve the experience and ensure your photo displays immediately rather than loading lazily.',
  },
  {
    q: 'What HR software platforms use a 400 KB upload limit?',
    a: 'Several HR software platforms cap candidate profile photos at 400 KB. These include some versions of BambooHR, Keka HR, Darwinbox, and HROne — all popular with Indian enterprises. Some company-specific application portals built on these platforms inherit the same limit. If you receive an upload error on an HR portal, 400 KB is a common threshold to try.',
  },
  {
    q: 'What dimensions should a LinkedIn or professional profile photo be?',
    a: 'LinkedIn displays profile photos at 400×400 px (1:1 square ratio) but accepts rectangular photos and crops them. For best results, upload a square photo at 800×800 px or 1000×1000 px. At 400 KB, an 800×800 px JPEG will be at approximately quality 88–92% — excellent for professional use. The high quality ensures your photo looks sharp on retina/HDPI displays.',
  },
  {
    q: 'What is the ideal photo size for real estate agent profiles?',
    a: 'Real estate agent profile photos on platforms like MagicBricks and 99acres benefit from 300–500 KB. At 400 KB and 600×800 px, a professional headshot for an agent profile looks crisp and trustworthy. Real estate platforms often display agent photos larger than job portal thumbnails — around 150–200 px on listings — making quality more visible.',
  },
  {
    q: 'Is 400 KB considered "web-safe" for general uploads?',
    a: 'Yes. 400 KB is broadly web-safe — it loads in under 0.5 seconds on a typical 4G connection (which averages 25 Mbps in India) and under 2 seconds on a slow 3G connection. For a single profile photo (not a gallery or banner), 400 KB is fast enough for any modern use case. It is only when you have multiple large images on a single page that you need to push toward 100–200 KB per image.',
  },
  {
    q: 'Does this compressor work for wedding photography previews?',
    a: 'Yes. Wedding photographers often use gallery preview images of 300–500 KB for online client approval galleries. At 400 KB and full portrait resolution (1200×1800 px or similar), the compressed JPEG looks excellent as a web preview — clients can see sharpness and expression clearly without the photographer sharing raw or print-quality files. Download speed is also fast enough for galleries with dozens of previews.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-400kb#app`,
      name: 'Compress Image to 400 KB Online Free',
      description: 'Compress any JPG, PNG, or WebP image to under 400 KB online. Free, no upload, 100% private. For LinkedIn profiles, HR portals, real estate, and professional web photos.',
      url: `${siteConfig.domain}/compress-image-to-400kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 400 KB — Free, No Upload"
  description="Free tool to compress any image to under 400 KB. 100% private, no upload. For LinkedIn profiles, HR platforms, real estate portals, and professional web photos. JPG, PNG, WebP."
  canonical={`${siteConfig.domain}/compress-image-to-400kb`}
  keywords="compress image to 400kb, reduce to 400kb, compress photo 400kb, professional photo compress"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-400kb" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 400 KB Online</h1>
        <p class="tool-desc">Free tool to compress any photo to under 400 KB. 100% private, no upload. For LinkedIn profile photos, HR platform uploads, real estate agent profiles, and professional web images.</p>
      </header>

      <CompressTool targetKB={400} />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Compress Image to 400 KB — Professional Profiles &amp; Web Images</h2>
        <p>400 KB occupies an important niche: large enough to produce a genuinely sharp, high-quality photo at professional dimensions, yet small enough to load quickly on any internet connection. This is why LinkedIn recommends profile photos under 400 KB, why many HR software platforms set this as their upload limit, and why wedding photographers and real estate professionals routinely target 300–500 KB for web preview galleries.</p>
        <p>At 400 KB, a JPEG photo at 1000×1000 px (suitable for LinkedIn's square crop) uses approximately a quality setting of 85–90% — the widely-accepted professional sweet spot. You get sharp, detailed rendition of facial features, skin tone gradients, hair texture, and fabric detail. The photo is "web-safe" in the sense that it loads in under half a second on typical mobile connections, making it suitable for any professional online presence.</p>
        <p>This free compressor targets exactly 400 KB, processing your image locally in the browser with no upload and no server-side processing.</p>

        <h3>LinkedIn Profile Photo — Getting It Right at 400 KB</h3>
        <p>LinkedIn is the world's largest professional network, and your profile photo is the first thing recruiters see. LinkedIn crops profile photos to a circle at 400×400 px display size, but accepts rectangular images. The recommended approach:</p>
        <ol>
          <li>Use a square or near-square photo. Shoot at 1:1 or crop to approximately 800×800 px or 1000×1000 px.</li>
          <li>Professional background — plain white, grey, or a blurred out-of-focus office/outdoor setting.</li>
          <li>Face occupies 60–70% of the frame. Look directly at the camera, smile naturally.</li>
          <li>Upload to this tool. Target is pre-set to 400 KB. Select JPEG output.</li>
          <li>Download and upload directly to LinkedIn. The platform will let you crop and adjust the circular crop.</li>
        </ol>

        <h3>400 KB Is a "Web-Safe" Size — Here's Why That Matters</h3>
        <p>A 400 KB file takes approximately 0.13 seconds to download on a 25 Mbps connection (India's average 4G speed). Even on a 5 Mbps connection (common in tier-2 and tier-3 cities), 400 KB downloads in 0.64 seconds. Compare this to a 4 MB raw camera export, which would take 1.28 seconds on 25 Mbps and 6.4 seconds on 5 Mbps. For single-image profiles — LinkedIn, HR portals, real estate agent pages — 400 KB is the practical maximum that respects your audience's connection speed.</p>
        <p>For even larger files where quality is paramount, see <a href="/compress-image-to-500kb">Compress to 500 KB</a>. For slightly smaller professional images, see <a href="/compress-image-to-300kb">Compress to 300 KB</a>. For JPEG-specific compression without a fixed target, use the <a href="/compress-jpg">Compress JPG</a> quality slider.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-300kb" class="related-card">
            <span class="related-name">Compress to 300 KB</span>
            <span class="related-desc">E-commerce &amp; blog images</span>
          </a>
          <a href="/compress-image-to-500kb" class="related-card">
            <span class="related-name">Compress to 500 KB</span>
            <span class="related-desc">University portals &amp; high quality</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Custom quality &amp; size target</span>
          </a>
          <a href="/compress-jpg" class="related-card">
            <span class="related-name">Compress JPG</span>
            <span class="related-desc">JPEG quality slider control</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
