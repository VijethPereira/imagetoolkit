---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'What is WebP and why should I convert to it?',
    a: 'WebP is a modern image format developed by Google. It uses more advanced compression algorithms than JPEG, producing files that are 25–34% smaller at the same visual quality. For websites, this means faster page load times, lower bandwidth costs, and better Core Web Vitals scores — all of which contribute to better search rankings.',
  },
  {
    q: 'Is WebP smaller than JPEG?',
    a: 'Yes — WebP lossy files are typically 25–34% smaller than JPEG at equivalent visual quality. For a website serving thousands of images, this difference significantly reduces bandwidth costs and improves page load times. A product image that is 250 KB as JPEG might be 170 KB as WebP at identical perceived quality.',
  },
  {
    q: 'Do all browsers support WebP?',
    a: 'Yes. As of 2024, all major modern browsers fully support WebP — including Chrome, Firefox, Safari (from version 14, released 2020), Edge, and all current mobile browsers. For most modern web projects, WebP is safe to use without a JPEG fallback.',
  },
  {
    q: 'When should I keep JPEG instead of converting to WebP?',
    a: 'Keep JPEG when: uploading to government portals or exam sites that require JPEG explicitly; sending images by email to recipients who use older software; preparing images for professional photo labs (which require JPEG or TIFF); or uploading to platforms that do not yet support WebP. For everything web-facing, WebP is the better choice.',
  },
  {
    q: 'Can I convert multiple JPGs to WebP at once?',
    a: 'Not yet — this tool converts one image at a time. For batch conversion, command-line tools like cwebp (Google\'s official encoder), Sharp, or ImageMagick can process entire folders. For most one-off web optimisation tasks, converting individually here is practical.',
  },
  {
    q: 'Is this free and does it upload my image to a server?',
    a: 'Completely free with no account required. All conversion happens in your browser using the Canvas API — your image is never uploaded to any server. The process is instant and 100% private.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/jpg-to-webp#app`,
      name: 'JPG to WebP Converter Online Free',
      description: 'Convert JPEG to WebP online free. WebP files are 25–34% smaller than JPEG at the same quality. No upload, 100% private. For faster websites and web images.',
      url: `${siteConfig.domain}/jpg-to-webp`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="JPG to WebP Converter — Free Online"
  description="Free JPG to WebP converter online. WebP is 25–34% smaller than JPEG. No upload, 100% private. Improve website speed and Core Web Vitals instantly."
  canonical={`${siteConfig.domain}/jpg-to-webp`}
  keywords="jpg to webp, jpeg to webp converter, convert jpg to webp online, jpg to webp free, jpeg webp converter"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/jpg-to-webp" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>JPG to WebP Converter — Free</h1>
        <p class="tool-desc">Convert JPEG images to WebP format free online. WebP files are 25–34% smaller than JPEG at the same quality. No upload, 100% private. Improve page speed instantly.</p>
      </header>

      <ConvertTool from="JPG" to="webp" />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Convert JPG to WebP Online — Smaller Files, Faster Pages</h2>
        <p>WebP is Google's open image format, released in 2010 and now the default choice for web images across major platforms. Its advanced compression algorithms encode the same visual information in 25–34% fewer bytes than JPEG. For web developers and site owners, converting JPEG photos to WebP is one of the highest-impact optimisations available — faster page loads, lower bandwidth costs, and improved Core Web Vitals scores, which directly influence Google search rankings.</p>
        <p>A typical product image that weighs 300 KB as a JPEG might be 200 KB as a WebP at identical visual quality. Multiply this across a catalogue of hundreds of product images and the cumulative performance gain is substantial. Google's PageSpeed Insights and Lighthouse audits explicitly recommend serving images in next-generation formats like WebP as a best practice.</p>
        <p>This free online converter works entirely in your browser. Your JPEG is decoded, drawn onto an HTML5 Canvas at full resolution, and re-encoded as WebP using the browser's native WebP encoder. Nothing is uploaded to any server — conversion is instant and completely private.</p>

        <h3>How to Convert JPG to WebP</h3>
        <ol>
          <li><strong>Upload your JPEG.</strong> Click "Choose File" or drag and drop your .jpg or .jpeg image.</li>
          <li><strong>Set quality.</strong> The default of 80% works well for most web images — excellent visual quality at minimum file size. Increase to 90%+ for images where colour accuracy is critical; decrease to 70% or lower for aggressive size reduction.</li>
          <li><strong>Convert and compare.</strong> Click "Convert". The tool shows the before/after file size comparison — you will typically see a 25–35% reduction.</li>
          <li><strong>Download the WebP.</strong> Download the .webp file and replace the JPEG in your HTML or CMS. No other code changes are needed — modern browsers load WebP natively.</li>
        </ol>

        <h3>When to Use WebP vs. JPEG</h3>
        <p><strong>Use WebP for:</strong> Web pages, blogs, e-commerce product images, CMS uploads, landing pages, and any image displayed in a modern browser. WebP is supported by all browsers released after 2020.</p>
        <p><strong>Stick with JPEG for:</strong> Government exam portals and recruitment sites (which often explicitly require JPEG), photo printing services, email attachments for recipients using older software, and platforms that do not yet accept WebP uploads.</p>
        <p><strong>For Indian government portals (SSC, UPSC, IBPS, NTA):</strong> These require JPEG format. Do not convert to WebP for exam photo uploads. Use the <a href="/compress-image">image compressor</a> to reduce JPEG size instead.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/png-to-webp" class="related-card">
            <span class="related-name">PNG to WebP</span>
            <span class="related-desc">Smaller web images with transparency</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Reduce JPEG/PNG file size</span>
          </a>
          <a href="/webp-to-jpg" class="related-card">
            <span class="related-name">WebP to JPG</span>
            <span class="related-desc">Convert back for portals</span>
          </a>
          <a href="/compress-image-to-100kb" class="related-card">
            <span class="related-name">Compress to 100 KB</span>
            <span class="related-desc">For job portals &amp; web</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
