---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'What is WebP?',
    a: 'WebP is a modern image format developed by Google that provides superior lossy and lossless compression for web images. It was designed specifically to replace JPEG and PNG on the web by producing smaller files at the same visual quality. WebP supports both lossy compression (like JPEG) and lossless compression (like PNG), as well as transparency and animation.',
  },
  {
    q: 'Is WebP smaller than JPEG?',
    a: 'Yes — WebP lossy files are typically 25–34% smaller than JPEG files at equivalent visual quality. For a website serving thousands of images, this difference can significantly reduce bandwidth costs and improve page load times. Google\'s own research shows WebP produces files that are on average 30% smaller than JPEG.',
  },
  {
    q: 'Do all browsers support WebP?',
    a: 'Yes, as of 2024 all major modern browsers fully support WebP — including Chrome, Firefox, Safari (from version 14, released 2020), Edge, and all mobile browsers. If you need to support Internet Explorer 11 or very old Safari versions, you would need to provide a JPEG fallback, but for most modern web projects WebP is safe to use.',
  },
  {
    q: 'Can I convert multiple JPGs to WebP at once?',
    a: 'Not yet — this tool converts one image at a time. For batch conversion of many images, command-line tools like cwebp (Google\'s official WebP encoder) or image processing tools like Sharp or ImageMagick can process entire folders. For most one-off web needs, converting individually is perfectly practical.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/jpg-to-webp#app`,
      name: `JPG to WebP Converter — ${siteConfig.siteName}`,
      description: 'Convert JPEG images to WebP format online for free. WebP files are 25–34% smaller than JPEG at the same quality.',
      url: `${siteConfig.domain}/jpg-to-webp`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="JPG to WebP Converter Online — Free"
  description="Convert JPEG images to WebP format online for free. WebP files are 25–34% smaller than JPEG at the same quality."
  canonical={`${siteConfig.domain}/jpg-to-webp`}
  keywords="jpg to webp, jpeg to webp converter, convert jpg to webp online"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/jpg-to-webp" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>JPG to WebP Converter</h1>
        <p class="tool-desc">Convert JPEG images to WebP format online for free. WebP files are 25–34% smaller than JPEG at the same quality.</p>
      </header>

      <ConvertTool from="JPG" to="webp" />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>WebP is Google's open image format, released in 2010 and now the standard choice for images on modern websites. It uses more advanced compression algorithms than JPEG, allowing it to encode the same visual information in 25–34% fewer bytes. For web developers and site owners, this means faster page load times, lower bandwidth consumption, and improved Core Web Vitals scores — all of which contribute to better search engine rankings.</p>
        <p>Converting your JPEG photos to WebP before uploading to your website is one of the highest-impact optimisations you can make. A product image that was 250 KB as a JPEG might be 170 KB as WebP at identical perceived quality. Multiply this across a catalogue of hundreds of images and the bandwidth and performance gains are substantial.</p>
        <p>There are still situations where you should stick with JPEG: when uploading to government portals or exam sites that specifically require JPEG, when sending photos via email to people who might open them in older software, or when preparing images for professional printing. For everything web-facing, WebP is the better choice.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your JPEG image onto the tool.</li>
          <li>Adjust the quality slider if needed (default of 80% works well for most images).</li>
          <li>Click "Convert" — the tool will encode your JPEG as WebP using the Canvas API.</li>
          <li>Review the file size comparison and download the WebP file.</li>
          <li>Upload the WebP to your website or CMS in place of the original JPEG.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
