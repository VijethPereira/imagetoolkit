---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${siteConfig.domain}/about#page`,
      url: `${siteConfig.domain}/about`,
      name: 'About Snap Image Tools',
      description: 'Learn about Snap Image Tools — a free suite of browser-based image tools for compression, resizing, and format conversion. No upload, 100% private.',
      isPartOf: { '@id': `${siteConfig.domain}/#website` },
    },
    {
      '@type': 'Organization',
      '@id': `${siteConfig.domain}/#org`,
      name: siteConfig.siteName,
      url: siteConfig.domain,
      founder: {
        '@type': 'Person',
        name: 'Vijeth Pereira',
        url: 'https://vijeth-portfolio.pages.dev/',
      },
    },
  ],
};
---

<Layout
  title="About Snap Image Tools — Free Browser-Based Image Compressor"
  description="Learn about Snap Image Tools — a free suite of 16 browser-based image tools for compression, resizing, and format conversion. No upload required, 100% private."
  canonical={`${siteConfig.domain}/about`}
  keywords="about snap image tools, free image compressor, browser based image tools, no upload image tools"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/about" />

  <main class="page-main">
    <div class="page-container">

      <div class="page-header">
        <div class="page-tag">About</div>
        <h1>About Snap Image Tools</h1>
        <p class="page-lead">
          A free suite of 16 browser-based image tools — compress, resize, and convert images entirely on your device. No upload, no sign-up, no guesswork.
        </p>
      </div>

      <div class="prose">
        <h2>What Is Snap Image Tools?</h2>
        <p>
          Snap Image Tools is a collection of free, browser-based image processing tools. Every tool runs
          entirely in your browser using the HTML5 Canvas API — nothing is installed, no account is required,
          and your images never leave your device.
        </p>
        <p>Currently available across three categories:</p>
        <ul>
          <li><strong>Compress Image</strong> — reduce file size while preserving the highest possible quality using a quality slider.</li>
          <li><strong>Compress to 20 KB</strong> — auto-compress to under 20 KB, the standard SSC exam photo and signature limit.</li>
          <li><strong>Compress to 50 KB</strong> — hit the 50 KB limit required by UPSC, NTA, and many state PSC portals.</li>
          <li><strong>Compress to 100 KB</strong> — binary-search compression to stay under 100 KB for banking and railway portals.</li>
          <li><strong>Compress to 200 KB</strong> — compress to under 200 KB for high-resolution form uploads.</li>
          <li><strong>Resize Image</strong> — resize to any custom pixel dimensions with aspect-ratio lock.</li>
          <li><strong>Passport Size Photo</strong> — resize to 413×531 px (35×45 mm), the standard Indian passport and visa photo size.</li>
          <li><strong>SSC Signature Resize</strong> — resize signatures to the exact SSC exam dimensions (276×118 px, max 12 KB).</li>
          <li><strong>Resize to 600×600</strong> — square crop and resize for social profiles and government forms.</li>
          <li><strong>Resize to 200×200</strong> — resize to 200×200 px for avatars and thumbnails.</li>
          <li><strong>JPG to WebP</strong> — convert JPEG images to WebP for 25–34% smaller files on the web.</li>
          <li><strong>PNG to WebP</strong> — convert PNG to WebP while preserving alpha-channel transparency.</li>
          <li><strong>WebP to JPG</strong> — convert WebP to universally compatible JPEG for portals and email.</li>
          <li><strong>WebP to PNG</strong> — convert WebP to lossless PNG for design tools and editing workflows.</li>
          <li><strong>JPG to PNG</strong> — convert JPEG to lossless PNG.</li>
          <li><strong>PNG to JPG</strong> — convert PNG to JPEG for the smallest file size.</li>
        </ul>

        <h2>Why We Built It</h2>
        <p>
          Most online image tools upload your photos to a remote server, process them, and send them back.
          This means your personal photos travel over the internet and may be stored on someone else's
          infrastructure — often without clear data-retention policies.
        </p>
        <p>
          Snap Image Tools was built differently. Every operation runs in the browser using the HTML5
          Canvas API. The key benefits:
        </p>
        <ul>
          <li><strong>Privacy</strong> — your images never leave your device. No server, no cloud storage.</li>
          <li><strong>Speed</strong> — no upload or download wait time, even for large files. Processing is instant.</li>
          <li><strong>Free forever</strong> — no subscriptions, no per-use credits, no daily limits.</li>
          <li><strong>No sign-up</strong> — no account, no email, no password required.</li>
          <li><strong>Works on mobile</strong> — fully responsive, touch-friendly, tested on Android and iOS.</li>
        </ul>

        <h2>Who Uses Snap Image Tools?</h2>
        <p>
          Our tools are most popular with students and job applicants preparing documents for Indian government
          exam portals — SSC CGL, SSC CHSL, IBPS PO, IBPS Clerk, UPSC, RRB NTPC, NTA JEE/NEET, and state
          PSC portals all impose strict photo and signature size requirements. The dedicated compress-to-KB
          tools hit those targets with a single click.
        </p>
        <p>
          Web developers and e-commerce operators use the conversion tools to optimise product images —
          converting JPEGs and PNGs to WebP for Core Web Vitals improvements and faster page loads.
          Social media managers use the resize tools to prepare profile photos for WhatsApp, Instagram,
          LinkedIn, and Facebook. Photographers use the compress tools to reduce attachment sizes for email.
        </p>

        <h2>What's Coming Next</h2>
        <p>
          More tools are in development — including batch processing, a background remover, a watermark
          tool, an image cropper, and additional size presets for international passport formats. If you
          have a specific tool in mind, <a href="/contact">get in touch</a> — we'd love to hear it.
        </p>

        <h2>Who Made This?</h2>
        <p>
          Snap Image Tools is designed and built by <strong>Vijeth Pereira</strong>, an independent developer
          focused on building fast, free, and privacy-first web tools.
          You can learn more at <a href="https://vijeth-portfolio.pages.dev/" target="_blank" rel="noopener noreferrer">vijeth-portfolio.pages.dev</a>.
          Also check out <a href="https://quickmeasuretool.com" target="_blank" rel="noopener noreferrer">Quick Measure Tool</a> — free online ruler and measurement tools.
        </p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main { background: var(--site-bg); }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }
  .page-header { margin-bottom: 48px; }
  .page-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--site-text-muted);
    margin-bottom: 16px;
    font-family: var(--font-mono, ui-monospace, monospace);
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--site-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .page-lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--site-body);
    margin: 0;
    max-width: 560px;
  }
  .prose h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--site-text);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .prose p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin: 0 0 1rem;
  }
  .prose ul {
    padding-left: 1.5rem;
    margin: 0.5rem 0 1rem;
  }
  .prose li {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin-bottom: 0.5rem;
  }
  .prose strong { color: var(--site-text); font-weight: 600; }
  .prose a { color: var(--site-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { opacity: 0.8; }
</style>
