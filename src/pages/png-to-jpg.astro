---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Will PNG transparency be preserved when converting to JPEG?',
    a: 'No. JPEG does not support transparency. Any transparent areas in your PNG will be filled with a white background in the JPEG output. If your PNG has a transparent background (such as a logo or icon), and you need to keep it transparent, use PNG or WebP instead. If a white background is acceptable, converting to JPEG is fine.',
  },
  {
    q: 'Why is my PNG so much larger than the equivalent JPEG?',
    a: 'PNG uses lossless compression, which stores every pixel exactly as-is. This makes PNG files very large for photographs because photos have thousands of unique pixel colours that do not compress well losslessly. JPEG uses lossy compression that discards colour information the eye barely notices, achieving far smaller file sizes. A photograph that is 4 MB as PNG might be only 300–500 KB as JPEG at good quality.',
  },
  {
    q: 'What quality setting should I use when converting PNG to JPEG?',
    a: 'For photographs, 80–85% quality gives an excellent balance — the image looks virtually indistinguishable from the source PNG at a fraction of the file size. For images with text or sharp graphics (screenshots, charts), use 90–95% to avoid JPEG artefacts on hard edges. If you need to meet a specific file size limit, lower the quality until the output falls within the required range.',
  },
  {
    q: 'Can I compress the resulting JPG further?',
    a: 'Yes. After converting your PNG to JPEG here, you can use the Compress Image tool on this site to target a specific file size — for example, if you need the photo under 50 KB for a government exam portal. The combination of format conversion plus targeted compression usually gives the best result.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/png-to-jpg#app`,
      name: `PNG to JPG Converter — ${siteConfig.siteName}`,
      description: 'Convert PNG images to JPEG online free. Smaller file size, great for photos and web use.',
      url: `${siteConfig.domain}/png-to-jpg`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="PNG to JPG Converter Online — Free"
  description="Convert PNG images to JPEG online free. Smaller file size, great for photos and web use."
  canonical={`${siteConfig.domain}/png-to-jpg`}
  keywords="png to jpg, convert png to jpeg, png jpg converter online"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/png-to-jpg" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>PNG to JPG Converter</h1>
        <p class="tool-desc">Convert PNG images to JPEG online free. Smaller file size, great for photos and web use.</p>
      </header>

      <ConvertTool from="PNG" to="jpeg" />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>Converting PNG to JPEG is one of the most effective ways to dramatically reduce file size for photographic images. PNG's lossless compression is excellent for graphics, logos, and images with transparent backgrounds, but it is highly inefficient for photographs where tiny colour variations in every pixel prevent significant compression. JPEG was designed specifically for photographs and achieves compression ratios that are 10–20 times better than PNG for typical photos.</p>
        <p>Common situations where you should convert PNG to JPEG: when you have exported a photo from a design tool as PNG and need a smaller file for web upload; when a government or job portal requires JPEG format; when you want to email a large PNG photo and need to reduce its size; or when you are uploading product images to an e-commerce platform that requires JPEG.</p>
        <p>Note that JPEG does not support transparency. If your PNG has transparent areas (visible as a checkerboard pattern in image editors), those areas will become white in the JPEG. For logos and icons where transparency is essential, do not convert to JPEG — use PNG or WebP instead.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your PNG image onto the tool.</li>
          <li>JPEG is pre-selected as the output format.</li>
          <li>Adjust the quality slider — 80% works well for most photographs.</li>
          <li>Click "Convert" and compare the file sizes before downloading.</li>
          <li>If you need to reach a specific file size limit, <a href="/compress-image">use the compressor</a> after conversion.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
