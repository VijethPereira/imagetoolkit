---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Which portals require images under 50 KB?',
    a: 'The 50 KB limit is used by UPSC (IAS/IPS/IFS applications on upsc.gov.in), NTA for JEE Main, NEET-UG, and CUET on ntaonline.in, most state government job portals, many university admission portals, and online forms for banks and insurance companies. It is the single most common photo size limit on Indian government websites.',
  },
  {
    q: 'What if my photo is already under 50 KB?',
    a: 'If your photo is already smaller than 50 KB, you do not need to compress it. You can still run it through this tool if you want to reduce it further, but uploading an image that is already within the limit is perfectly fine.',
  },
  {
    q: 'Should I use JPEG or PNG for a 50 KB upload?',
    a: 'Use JPEG for photographs — a typical passport-size JPEG can be compressed to under 50 KB while still looking good. PNG is lossless and will be much larger for the same visual quality; avoid PNG for exam photo uploads unless the portal specifically requires it.',
  },
  {
    q: 'My photo keeps coming out with too low quality after compression.',
    a: 'This usually happens when the original image is very large (e.g., 3–5 MB) and heavy compression is needed to reach 50 KB. The fix is to first resize your photo to a smaller pixel dimension — 200×230 px for portraits is a good starting point — and then compress to 50 KB. Smaller images need less compression to meet the size limit, so quality is much better preserved.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-50kb#app`,
      name: `Compress Image to 50 KB — ${siteConfig.siteName}`,
      description: 'Compress any image to under 50 KB online. Required for UPSC, banking exams, college admissions, and most Indian govt portals.',
      url: `${siteConfig.domain}/compress-image-to-50kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 50 KB Online — Free"
  description="Compress any image to under 50 KB online. Required for UPSC, banking exams, college admissions, and most Indian govt portals."
  canonical={`${siteConfig.domain}/compress-image-to-50kb`}
  keywords="compress image to 50kb, reduce image to 50kb, compress photo to 50kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-50kb" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 50 KB</h1>
        <p class="tool-desc">Compress any image to under 50 KB online. Required for UPSC, banking exams, college admissions, and most Indian govt portals.</p>
      </header>

      <CompressTool targetKB={50} />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>50 KB is the most common photograph size limit on Indian government and education portals. UPSC requires applicants to upload a photo under 50 KB on upsc.gov.in. NTA's portals for JEE Main, NEET-UG, and CUET enforce the same 50 KB limit. State government recruitment boards, central university admission portals, and most public sector bank job applications use this threshold as well.</p>
        <p>This tool automatically compresses your image until it falls under 50 KB, then stops — preserving as much quality as possible at that target. The process happens entirely in your browser; nothing is uploaded to a server. You can compress the same photo multiple times with different settings without any privacy concern.</p>
        <p>For UPSC and NTA applications in particular, the photograph must typically be recent, show a clear face against a white or light background, and be in JPEG format. Use the quality result preview to confirm the image still clearly shows your face before submitting.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your photo onto the tool.</li>
          <li>The target is pre-set to 50 KB — no adjustment needed.</li>
          <li>Ensure the output format is JPEG for photographs.</li>
          <li>Click "Compress" — the tool finds the optimal quality setting automatically.</li>
          <li>Review the compressed image and download if acceptable.</li>
          <li>If quality is too low, try <a href="/resize-image-to-passport-size">resizing to passport dimensions</a> first, then compress.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
