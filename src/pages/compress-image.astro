---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Does compression reduce image quality?',
    a: 'Yes, lossy compression (used for JPEG and WebP) does reduce quality slightly, but at settings of 75–85% the difference is rarely visible to the naked eye. The goal is to find the highest quality setting that still meets your file size requirement.',
  },
  {
    q: 'What is the best quality setting to use?',
    a: 'For photographs shared online, 80% quality is a good starting point — it typically reduces file size by 60–70% with minimal visible loss. For images that need to look pixel-perfect (logos, screenshots), use 90% or higher. For very aggressive compression (government exam uploads), 60–70% is often acceptable.',
  },
  {
    q: 'What image formats are supported?',
    a: 'This tool supports JPEG (JPG), PNG, and WebP images. You can also choose the output format — for example, converting a PNG to JPEG during compression often produces much smaller files since JPEG handles photographs more efficiently.',
  },
  {
    q: 'Is my image uploaded to a server?',
    a: 'No. Everything happens entirely in your browser using the HTML5 Canvas API. Your image never leaves your device and is never sent to any server. This means your photos remain 100% private.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image#app`,
      name: `Compress Image Online — ${siteConfig.siteName}`,
      description: 'Compress JPG, PNG, and WebP images online for free. Reduce file size with quality control — no upload, 100% private.',
      url: `${siteConfig.domain}/compress-image`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image Online — Reduce File Size Free"
  description="Compress JPG, PNG, and WebP images online for free. Reduce file size with quality control — no upload, 100% private."
  canonical={`${siteConfig.domain}/compress-image`}
  keywords="compress image, reduce image size, compress jpg, compress png online"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image Online</h1>
        <p class="tool-desc">Compress JPG, PNG, and WebP images online for free. Reduce file size with quality control — no upload, 100% private.</p>
      </header>

      <CompressTool />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>Image compression reduces file size by discarding redundant pixel data that the human eye cannot easily perceive. JPEG and WebP use lossy compression algorithms that can cut file sizes by 60–80% at typical quality settings while keeping images looking sharp. PNG uses lossless compression, which preserves every pixel but produces larger files.</p>
        <p>The quality slider lets you balance file size against visual fidelity. For most web and social media uses, a setting of 75–85% produces excellent results. For government exam and form uploads where the examiner is checking identity rather than image aesthetics, settings as low as 60% are often acceptable.</p>
        <p>Common use cases include preparing photos for email attachments (many email clients impose a 5–10 MB total limit), meeting upload size requirements on job portals and e-commerce platforms, and compressing photos before sending on WhatsApp (which recompresses images automatically, often degrading quality further if files are already large).</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your image onto the tool.</li>
          <li>Adjust the quality slider — lower values create smaller files with more compression.</li>
          <li>Optionally select an output format (JPEG, PNG, or WebP).</li>
          <li>Click "Compress" and review the before/after file size comparison.</li>
          <li>Download the compressed image when you are satisfied with the result.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
