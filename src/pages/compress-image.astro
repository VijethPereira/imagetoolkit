---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'How do I compress an image to 100 KB without losing quality?',
    a: 'Use the "Compress to 100 KB" tool which automatically finds the highest JPEG quality that keeps the output under 100 KB. For the best visual result, first resize your photo to the target pixel dimensions, then compress. Smaller dimensions need far less compression to reach the KB target, so the image looks sharper.',
  },
  {
    q: 'Is it safe to compress images online?',
    a: 'Yes — because this tool runs entirely in your browser using the HTML5 Canvas API. Your images are never uploaded to any server, never transmitted over the internet, and never stored anywhere other than your own device. It is the most private way to compress images online.',
  },
  {
    q: 'How do I reduce image size in KB for free?',
    a: 'Drop your image onto the tool and use the quality slider to reduce file size. A setting of 75–80% quality typically reduces file size by 60–70% with minimal visible quality loss. For a specific KB target, use the dedicated tools: Compress to 20 KB, Compress to 50 KB, or Compress to 100 KB.',
  },
  {
    q: 'What is the difference between JPEG and WebP compression?',
    a: 'JPEG uses lossy compression optimised for photographs and is universally supported everywhere — email, government portals, social media, printers. WebP is Google\'s modern format that achieves 25–34% smaller file sizes than JPEG at the same quality. Choose JPEG for maximum compatibility (especially for government exam uploads); choose WebP for web images where modern browser support is guaranteed.',
  },
  {
    q: 'Can I compress a PNG image online?',
    a: 'Yes. This tool accepts PNG files. However, PNG uses lossless compression so compressing a PNG without converting the format yields limited size reduction. For the biggest savings, switch the output format to JPEG or WebP — a photograph that is 2 MB as PNG might be only 150 KB as JPEG at good quality. If the image has a transparent background that must be preserved, output to WebP which supports transparency at smaller sizes than PNG.',
  },
  {
    q: 'Does compressing an image reduce its pixel dimensions?',
    a: 'No. Compression reduces file size (bytes) by encoding the same pixels more efficiently, but the width and height of the image do not change. If you also need to change dimensions, use the Resize Image tool first, then compress.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image#app`,
      name: 'Image Compressor Online',
      description: 'Free online image compressor. Compress JPG, PNG and WebP — reduce file size without losing quality. 100% private, no upload.',
      url: `${siteConfig.domain}/compress-image`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Image Compressor Online — Free No Upload"
  description="Free online image compressor. Compress JPG, PNG & WebP — reduce file size without losing quality. 100% private, no upload required."
  canonical={`${siteConfig.domain}/compress-image`}
  keywords="image compressor, compress image online, free image compressor, compress jpeg, compress png, photo compressor, compress image for web, image size reducer, reduce image size"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Image Compressor Online</h1>
        <p class="tool-desc">Free online image compressor — compress JPG, PNG &amp; WebP in your browser. Reduce file size without losing quality. 100% private, no upload.</p>
      </header>

      <CompressTool />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Free Image Compressor — Compress JPEG, PNG &amp; WebP Online</h2>
        <p>Image compression reduces the number of bytes required to store a photo by discarding pixel data that the human eye is least sensitive to. Our free online image compressor runs entirely in your browser using the HTML5 Canvas API — your photos never leave your device, making it the fastest and most private image compressor online.</p>

        <h3>Supported Image Formats</h3>
        <ul>
          <li><strong>JPEG (JPG)</strong> — The most efficient format for photographs. Lossy compression discards imperceptible colour variations, achieving 60–80% file size reduction at quality settings of 75–85%. Best for government exam uploads, job applications, e-commerce, and any context where file size matters more than absolute pixel perfection.</li>
          <li><strong>PNG</strong> — Lossless format for logos, screenshots, and images with transparency. Converting a PNG photograph to JPEG during compression typically produces 5–10× smaller files. If the image has a transparent background that must be preserved, convert to WebP instead.</li>
          <li><strong>WebP</strong> — Google's modern web format. 25–34% smaller than JPEG at equivalent visual quality, with full transparency support. All major browsers have supported WebP since 2020. Ideal for compressing images for websites and improving Core Web Vitals scores.</li>
        </ul>

        <h3>How to Use This Image Compressor</h3>
        <ol>
          <li><strong>Upload your image.</strong> Click the drop zone or drag and drop your JPG, PNG, or WebP file. Files up to 20 MB are supported.</li>
          <li><strong>Adjust compression.</strong> Use the quality slider to set the compression level. Settings of 75–85% work well for photographs shared online. For government exam portals where a strict file size limit applies, lower the slider until the output is within range — or use a dedicated compress-to-KB tool below.</li>
          <li><strong>Download the result.</strong> Click "Compress" and review the before/after file size. Download your compressed image when you are happy with the result.</li>
        </ol>

        <h3>Why Client-Side Compression Is Private and Fast</h3>
        <p>Most online photo compressors upload your images to a remote server to process them. This means your photos travel across the internet and may be temporarily stored on infrastructure you do not control — a real privacy concern for passport photos, ID photos, and documents. This free image compressor works differently: the Canvas API draws your image to an off-screen canvas and re-encodes it at your chosen quality level in milliseconds, entirely on your device. No upload. No waiting for network transfers. No privacy risk.</p>

        <h3>Common Use Cases</h3>
        <p><strong>Government and exam form uploads:</strong> Indian government exam portals for SSC, UPSC, IBPS, RRB NTPC, and NTA enforce strict file size limits — typically 20 KB, 50 KB, or 100 KB for photographs and signatures. Use our dedicated compress-to-KB tools to hit these targets precisely without manual trial and error.</p>
        <p><strong>Email attachments:</strong> Most email providers cap attachments at 10–25 MB. A batch of smartphone photos can easily fill this limit. Compressing images before attaching reduces upload time and makes emails faster to open on mobile.</p>
        <p><strong>Web pages and e-commerce:</strong> Oversized images are the most common cause of slow page load speeds. Google's Core Web Vitals directly reward pages with fast-loading images. Compress product images to under 100 KB (or convert to WebP) before uploading to your website or CMS to improve search rankings and conversion rates.</p>
        <p><strong>Reduce image size for WhatsApp:</strong> WhatsApp applies its own aggressive compression to images it sends, which can degrade quality further if the original is already large. Compressing before sending gives you control over the final quality.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-20kb" class="related-card">
            <span class="related-name">Compress to 20 KB</span>
            <span class="related-desc">SSC &amp; IBPS exam uploads</span>
          </a>
          <a href="/compress-image-to-50kb" class="related-card">
            <span class="related-name">Compress to 50 KB</span>
            <span class="related-desc">UPSC, NTA, banking portals</span>
          </a>
          <a href="/compress-image-to-100kb" class="related-card">
            <span class="related-name">Compress to 100 KB</span>
            <span class="related-desc">Job portals &amp; e-commerce</span>
          </a>
          <a href="/resize-image" class="related-card">
            <span class="related-name">Resize Image</span>
            <span class="related-desc">Change pixel dimensions</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol, .content-section ul { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
