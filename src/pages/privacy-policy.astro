---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const year = new Date().getFullYear();
---

<Layout
  title="Privacy Policy — Image Tools"
  description="Privacy policy for Image Tools. Your images are never uploaded to any server — all processing happens locally in your browser."
  canonical={`${siteConfig.domain}/privacy-policy`}
>
  <SiteNav currentPath="/privacy-policy" />

  <main class="page-main">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p class="updated">Last updated: {year}</p>

      <p>
        {siteConfig.siteName} takes your privacy seriously. This page explains what data
        we collect and how we use it.
      </p>

      <h2>Image data — not collected</h2>
      <p>
        All image processing on {siteConfig.siteName} happens entirely in your browser
        using the HTML5 Canvas API. When you open an image with any tool on this site,
        the image is loaded into your browser's local memory only. It is never transmitted
        to any server, never stored remotely, and never accessible to anyone other than you.
        We have no ability to see, access, or retain any image you process on this site.
      </p>
      <p>
        This is true for all tools: compress, resize, and format conversion. None of your
        image data ever leaves your device.
      </p>

      <h2>Local storage</h2>
      <p>
        We store a single key in <code>localStorage</code> to remember your dark/light
        mode preference across visits. This is stored only on your device and is never
        transmitted anywhere. You can clear it at any time by clearing your browser's
        site data for this domain.
      </p>

      <h2>Analytics</h2>
      {siteConfig.gaId ? (
        <p>
          We use Google Analytics (GA4) to understand aggregate traffic patterns — which
          tools are used most, which pages are visited, and which countries visitors come
          from. Google Analytics collects anonymised data including your browser type,
          approximate location (country/city level), device type, and pages visited.
          No personally identifiable information is collected. Google's data processing
          is governed by <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
          You can opt out of Google Analytics tracking using the
          <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics Opt-out Browser Add-on</a>.
        </p>
      ) : (
        <p>
          This site does not currently use analytics tracking.
        </p>
      )}

      <h2>Advertising</h2>
      {siteConfig.adsenseId ? (
        <p>
          This site displays advertisements through Google AdSense. Google may use cookies
          and similar technologies to serve ads based on your prior visits to this and
          other websites. You can opt out of personalised advertising by visiting
          <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener">Google's Ads Settings</a>.
          Google's use of advertising cookies is governed by
          <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google's Privacy Policy</a>.
        </p>
      ) : (
        <p>
          This site does not currently display third-party advertisements.
        </p>
      )}

      <h2>Cookies</h2>
      <p>
        {siteConfig.siteName} itself does not set any tracking cookies. The only browser
        storage used by this site is the <code>localStorage</code> entry for your
        dark/light mode preference described above.
        {siteConfig.adsenseId && ' Google AdSense may set cookies for advertising purposes as described above.'}
        {siteConfig.gaId && ' Google Analytics may set cookies for analytics purposes as described above.'}
      </p>

      <h2>Third-party links</h2>
      <p>
        This site may link to external websites. We are not responsible for the privacy
        practices of those sites. We encourage you to read the privacy policy of any
        website you visit.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        We may update this privacy policy from time to time. The date at the top of
        this page indicates when the policy was last revised.
      </p>

      <h2>Contact</h2>
      <p>
        For privacy-related questions, please use the <a href="/contact">contact page</a>.
      </p>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding: 3rem 0 6rem;
  }

  .container {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--site-text);
    margin: 0 0 0.5rem;
  }

  .updated {
    font-size: 0.875rem;
    color: var(--site-text-muted);
    margin: 0 0 1.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--site-text);
    margin: 2rem 0 0.5rem;
  }

  p {
    color: var(--site-text-muted);
    margin: 0 0 1rem;
    max-width: 65ch;
    line-height: 1.7;
  }

  a {
    color: var(--site-accent);
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--site-hover);
    padding: 0.1em 0.4em;
    border-radius: 4px;
  }
</style>
