---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const effectiveDate = 'July 17, 2025';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteConfig.domain}/privacy-policy#page`,
  url: `${siteConfig.domain}/privacy-policy`,
  name: 'Privacy Policy — Snap Image Tools',
  description: 'Privacy policy for Snap Image Tools. Learn how we use Google Analytics, Google AdSense, and what data is stored in your browser.',
  isPartOf: { '@id': `${siteConfig.domain}/#website` },
};
---

<Layout
  title="Privacy Policy — Snap Image Tools"
  description="Privacy policy for Snap Image Tools. Learn how we use Google Analytics, Google AdSense, and what data is stored locally in your browser. No personal data collected."
  canonical={`${siteConfig.domain}/privacy-policy`}
  keywords="snap image tools privacy policy, image compressor privacy, google adsense privacy, google analytics privacy"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/privacy-policy" />

  <main class="page-main">
    <div class="page-container">

      <div class="page-header">
        <div class="page-tag">Legal</div>
        <h1>Privacy Policy</h1>
        <p class="page-lead">
          Snap Image Tools is built with privacy at its core — your images never leave your device. This policy explains what data is collected, how it is used, and your choices.
        </p>
        <p class="effective-date">Effective date: {effectiveDate}</p>
      </div>

      <div class="prose">

        <h2>1. Information We Collect</h2>
        <p>
          Snap Image Tools does <strong>not</strong> require you to create an account or provide any personal
          information to use the tools. We do not sell personal data. All image processing happens entirely
          in your browser — your photos are never uploaded to any server.
        </p>
        <p>
          Your dark/light mode preference is saved in your <strong>browser's local storage</strong> on your
          own device and is never transmitted to our servers.
        </p>

        <h2>2. Local Storage</h2>
        <p>
          Snap Image Tools stores the following in your browser's <code>localStorage</code>:
        </p>
        <ul>
          <li><code>site-theme</code> — your dark/light mode preference. Used to restore your chosen theme on return visits.</li>
        </ul>
        <p>
          You can clear this data at any time by clearing your browser's site data, or by using your
          browser's developer tools to delete local storage entries for <code>snapimagetools.com</code>.
        </p>

        <h2>3. Cookies</h2>
        <p>
          Snap Image Tools uses the following cookies:
        </p>
        <ul>
          <li>
            <strong>Google Analytics cookies</strong> (<code>_ga</code>, <code>_gid</code>, <code>_ga_*</code>) —
            set by Google Analytics to distinguish users and sessions. Retained for up to 2 years.
            See <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's Privacy Policy</a>.
          </li>
          <li>
            <strong>Google AdSense cookies</strong> — set by Google to serve relevant advertisements.
            These may include the DoubleClick DART cookie and other identifiers used for ad personalisation
            and measurement. See <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's Privacy Policy</a>.
          </li>
        </ul>
        <p>
          You can clear cookies at any time via your browser settings.
        </p>

        <h2>4. Analytics</h2>
        <p>
          Snap Image Tools uses <strong>Google Analytics</strong> to understand aggregate usage patterns such as
          page views, popular tools, and device types. Google Analytics collects anonymised data including
          your approximate location (country/region), browser type, device type, and pages visited.
          No personally identifiable information is collected or stored by us through this service.
        </p>
        <p>
          Google's privacy policy applies:
          <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a>.
          You can opt out of Google Analytics tracking by installing the
          <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>.
        </p>

        <h2>5. Advertising</h2>
        <p>
          Snap Image Tools uses <strong>Google AdSense</strong> to display advertisements on this site.
          Google AdSense uses cookies and similar tracking technologies to serve ads based on your prior
          visits to this and other websites. Google's use of advertising cookies enables it and its partners
          to serve ads based on your visit to our site and/or other sites on the Internet.
        </p>
        <p>
          You may opt out of personalised advertising by visiting
          <a href="https://adssettings.google.com/" target="_blank" rel="noopener noreferrer">Google Ads Settings</a>
          or by visiting <a href="https://www.aboutads.info/choices/" target="_blank" rel="noopener noreferrer">aboutads.info/choices</a>.
          Google's privacy policy applies:
          <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">policies.google.com/privacy</a>.
        </p>

        <h2>6. Third-Party Services</h2>
        <ul>
          <li>
            <strong>FormSubmit.co</strong> — used to receive messages sent via the Contact page. When you
            submit the contact form, your name, email address, and message are transmitted to FormSubmit.co
            and forwarded to us by email. We retain contact messages only as long as necessary to respond.
          </li>
          <li>
            <strong>Google Fonts</strong> (if applicable) — may load typefaces from <code>fonts.googleapis.com</code>,
            which results in a request to Google's servers that may log your IP address.
          </li>
        </ul>

        <h2>7. Image Data</h2>
        <p>
          All image processing on Snap Image Tools occurs <strong>entirely within your browser</strong> using
          the HTML5 Canvas API. Your images are loaded into browser memory locally, processed, and made
          available for download — they are never uploaded to our servers or any third-party server. We have
          no access to the images you process.
        </p>

        <h2>8. Children's Privacy</h2>
        <p>
          Snap Image Tools is a general-purpose image tool suitable for all ages. We do not knowingly
          collect any personally identifiable information from children under 13. Google AdSense may
          display non-personalised ads to users in regions where personalised advertising is restricted.
        </p>

        <h2>9. Changes to This Policy</h2>
        <p>
          We may update this Privacy Policy from time to time. The effective date at the top of this page
          will reflect when the policy was last revised. Continued use of Snap Image Tools after any changes
          constitutes your acceptance of the updated policy.
        </p>

        <h2>10. Contact</h2>
        <p>
          If you have any questions about this Privacy Policy or how Snap Image Tools handles your data,
          please <a href="/contact">contact us</a>.
        </p>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main { background: var(--site-bg); }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }
  .page-header { margin-bottom: 48px; }
  .page-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--site-text-muted);
    margin-bottom: 16px;
    font-family: var(--font-mono, ui-monospace, monospace);
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--site-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .page-lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--site-body);
    margin: 0 0 8px;
    max-width: 560px;
  }
  .effective-date {
    font-size: 0.8125rem;
    color: var(--site-text-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    margin: 0;
  }
  .prose h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--site-text);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .prose p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin: 0 0 1rem;
  }
  .prose ul {
    padding-left: 1.5rem;
    margin: 0.5rem 0 1rem;
  }
  .prose li {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin-bottom: 0.5rem;
  }
  .prose strong { color: var(--site-text); font-weight: 600; }
  .prose code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.8125rem;
    background: var(--site-hover);
    border: 1px solid var(--site-border);
    border-radius: 4px;
    padding: 1px 5px;
    color: var(--site-text);
  }
  .prose a { color: var(--site-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { opacity: 0.8; }
</style>
