---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import CompressTool from '../components/tools/CompressTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Which state PSC portals use a 30 KB photo limit?',
    a: 'Bihar Public Service Commission (BPSC) 70th Combined Competitive Examination and other BPSC notifications, Jharkhand Public Service Commission (JPSC), and Uttar Pradesh Public Service Commission (UPPSC) Preliminary exams have all used 30 KB photo upload limits. State police recruitment boards including Bihar Police and UP Police also commonly use this limit. Always verify against the current official notification.',
  },
  {
    q: 'How is 30 KB different from 20 KB for exam photos?',
    a: 'At the standard exam photo resolution of 200×230 px, 30 KB allows a noticeably higher JPEG quality setting than 20 KB. Skin tones will appear smoother, edges sharper, and background gradients cleaner. However, both sizes are fully adequate for exam portal identity verification. Use 30 KB when your specific portal requires it — do not upload a 30 KB file to a portal that requires under 20 KB.',
  },
  {
    q: 'What are BPSC photo requirements for 2024–2025?',
    a: 'BPSC photo requirements have been consistent: JPEG format, recent photograph (not more than 3 months old), white or light background, file size under 30 KB, minimum dimensions typically 200×230 px. Signature requirements are separately specified (usually smaller, under 15–20 KB). Always check the specific BPSC Combined Competitive Examination notification for the current cycle\'s exact specifications.',
  },
  {
    q: 'Can I use this tool for UP Police constable recruitment photo?',
    a: 'Yes. UP Police constable and sub-inspector recruitment portals have used a 30 KB photo limit in recent notification cycles. Upload your photo here, ensure JPEG output is selected, and download the compressed file. Always cross-check with the current UP Police advertisement before submitting.',
  },
  {
    q: 'Why do police recruitment portals use 30 KB instead of 20 KB?',
    a: 'Police and state PSC portals tend to have slightly more relaxed file size limits than central government exam portals like SSC. 30 KB provides marginally better image clarity, which may help with identity verification at examination centres and document verification stages. The 10 KB difference from the SSC standard is practically negligible in terms of server storage across a large applicant pool.',
  },
  {
    q: 'Does the output format matter for state PSC portals?',
    a: 'Yes — virtually all Indian government exam portals require JPEG format. PNG files are typically rejected. This tool accepts PNG and WebP as input and converts them to JPEG. Make sure the output format is set to JPEG before downloading. Some portals also reject files with extensions like .JPG vs .jpg — download and check the file name if you encounter upload issues.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/compress-image-to-30kb#app`,
      name: 'Compress Image to 30 KB Online Free',
      description: 'Compress any JPG, PNG, or WebP image to under 30 KB online. Free, no upload, 100% private. For BPSC, JPSC, UPPSC, state PSC portals, and police recruitment boards.',
      url: `${siteConfig.domain}/compress-image-to-30kb`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Compress Image to 30 KB — Free, No Upload"
  description="Free tool to compress any image to under 30 KB. 100% private, no upload. For BPSC, JPSC, UPPSC, state PSC portals, and police recruitment boards. JPG, PNG, WebP."
  canonical={`${siteConfig.domain}/compress-image-to-30kb`}
  keywords="compress image to 30kb, reduce to 30kb, bpsc photo size, uppsc photo 30kb, compress photo 30kb"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/compress-image-to-30kb" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Compress Image to 30 KB Online</h1>
        <p class="tool-desc">Free tool to compress any photo to under 30 KB. 100% private, no upload. For BPSC, JPSC, UPPSC, state PSC exam portals, and police recruitment photo uploads.</p>
      </header>

      <CompressTool targetKB={30} />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Compress Image to 30 KB — BPSC, UPPSC &amp; State Police Recruitment</h2>
        <p>30 KB is a commonly used photo upload limit for state-level Public Service Commission examinations and police recruitment boards in India. Bihar Public Service Commission (BPSC), Jharkhand Public Service Commission (JPSC), and Uttar Pradesh Public Service Commission (UPPSC) are among the prominent exam bodies that have used 30 KB photo limits. State police recruitment boards — including those for Bihar Police Constable, UP Police Constable, and related posts — also frequently specify 30 KB.</p>
        <p>This limit is slightly more generous than the central government SSC standard of 20 KB and gives you a small but real improvement in photo clarity. At 30 KB and 200×230 px, JPEG compression is moderate — skin tones look natural and fine details like hair strands and eyebrows are visibly sharper than at 20 KB.</p>
        <p>This tool works entirely in your browser. It binary-searches for the highest JPEG quality that keeps your file under 30 KB. No uploads, no server, no account needed.</p>

        <h3>Step-by-Step: Prepare Your Photo for BPSC or UPPSC</h3>
        <ol>
          <li>Get a recent passport-size photograph. White or light background, face clearly visible, no shadows, no sunglasses. Many BPSC and UPPSC notifications specify the photo should be taken within the last 3 months.</li>
          <li>Resize to 200×230 px or the dimensions specified in your notification using the <a href="/resize-image-to-passport-size">Passport Size Photo Resizer</a>.</li>
          <li>Upload here. Target is pre-set to 30 KB.</li>
          <li>Select JPEG as output format.</li>
          <li>Click "Compress" and download. Verify the file size and image quality before submitting your application form.</li>
        </ol>

        <h3>30 KB vs 20 KB — Quality Difference Explained</h3>
        <p>A 200×230 px JPEG at 20 KB has approximately 446 bytes per kilopixel. At 30 KB, that rises to 670 bytes per kilopixel — about 50% more data to represent each pixel. This manifests as noticeably smoother skin tones, sharper edges around the hairline and shoulders, and cleaner background reproduction. In blind comparisons, most people can tell the two apart when shown side-by-side, though both look fine for exam portal purposes.</p>
        <p>If your notification permits 30 KB, there is no benefit to uploading a 20 KB file — use the full size budget for the best quality. For BPSC specifically, use the current BPSC Combined Competitive Examination notification PDF to confirm the exact photo and signature size requirements, as they can occasionally change between the 69th, 70th, and subsequent cycles.</p>
        <p>For smaller limits (state PSC signature files), see <a href="/compress-image-to-20kb">Compress to 20 KB</a> or <a href="/compress-image-to-15kb">Compress to 15 KB</a>. For portals with a larger limit, try <a href="/compress-image-to-50kb">Compress to 50 KB</a>.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/compress-image-to-20kb" class="related-card">
            <span class="related-name">Compress to 20 KB</span>
            <span class="related-desc">SSC CGL, IBPS, RRB NTPC</span>
          </a>
          <a href="/compress-image-to-50kb" class="related-card">
            <span class="related-name">Compress to 50 KB</span>
            <span class="related-desc">UPSC, college portals</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Custom quality &amp; size target</span>
          </a>
          <a href="/resize-image-to-passport-size" class="related-card">
            <span class="related-name">Passport Size Photo</span>
            <span class="related-desc">413×531 px / 35×45 mm</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .content-section a { color: var(--site-accent); }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
