---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${siteConfig.domain}/contact#page`,
  url: `${siteConfig.domain}/contact`,
  name: 'Contact — Snap Image Tools',
  description: 'Contact Snap Image Tools. Send feedback, report a bug, or request a new image tool.',
  isPartOf: { '@id': `${siteConfig.domain}/#website` },
};
---

<Layout
  title="Contact — Snap Image Tools"
  description="Get in touch with Snap Image Tools. Report a bug, request a feature, or suggest a new tool. We read every message and aim to respond within 2 business days."
  canonical={`${siteConfig.domain}/contact`}
  keywords="contact snap image tools, image compressor feedback, report bug image tool"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/contact" />

  <main class="page-main">
    <div class="page-container">

      <div class="page-header">
        <div class="page-tag">Contact</div>
        <h1>Get in Touch</h1>
        <p class="page-lead">
          Found a bug, have a feature request, or want to suggest a new tool? We read every message.
        </p>
      </div>

      <div class="contact-layout">

        <!-- Contact form -->
        <div class="contact-form-wrap">
          <form id="contact-form" class="contact-form" novalidate>
            <div class="field-group">
              <label for="cf-name">Name</label>
              <input
                id="cf-name"
                type="text"
                name="name"
                placeholder="Your name"
                required
                autocomplete="name"
              />
            </div>

            <div class="field-group">
              <label for="cf-email">Email</label>
              <input
                id="cf-email"
                type="email"
                name="email"
                placeholder="you@example.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="field-group">
              <label for="cf-subject">Subject</label>
              <select id="cf-subject" name="subject" required>
                <option value="" disabled selected>Select a topic…</option>
                <option value="Bug report">Bug report</option>
                <option value="Feature request">Feature request</option>
                <option value="Tool suggestion">Tool suggestion</option>
                <option value="General feedback">General feedback</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="field-group">
              <label for="cf-message">Message</label>
              <textarea
                id="cf-message"
                name="message"
                rows="5"
                placeholder="Describe your issue, idea, or question…"
                required
              ></textarea>
            </div>

            <div class="form-footer">
              <button type="submit" id="submit-btn" class="submit-btn">Send Message</button>
              <span id="form-error" class="form-error" style="display:none;">Something went wrong — please try again.</span>
            </div>
          </form>

          <!-- Success banner -->
          <div id="success-banner" class="success-banner" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Message sent — thank you! We'll get back to you soon.
          </div>
        </div>

        <!-- Side info -->
        <aside class="contact-aside">
          <div class="aside-card">
            <div class="aside-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 5v4.5L11.5 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="aside-title">Response time</div>
              <div class="aside-body">We aim to respond within 2 business days.</div>
            </div>
          </div>

          <div class="aside-card">
            <div class="aside-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M3 4h12v10a1 1 0 01-1 1H4a1 1 0 01-1-1V4z" stroke="currentColor" stroke-width="1.3"/>
                <path d="M3 4l6 5 6-5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="aside-title">Privacy</div>
              <div class="aside-body">Your message is sent via <a href="https://formsubmit.co" target="_blank" rel="noopener">FormSubmit</a> and forwarded to us by email. We never share your details.</div>
            </div>
          </div>

          <div class="aside-card">
            <div class="aside-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="7" r="3.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M2.5 16c0-3.59 2.91-6.5 6.5-6.5s6.5 2.91 6.5 6.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="aside-title">Also try</div>
              <div class="aside-body"><a href="https://quickmeasuretool.com" target="_blank" rel="noopener">Quick Measure Tool</a> — free online ruler &amp; measurement tools.</div>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form      = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const errorEl   = document.getElementById('form-error');
  const banner    = document.getElementById('success-banner');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    submitBtn.disabled    = true;
    submitBtn.textContent = 'Sending…';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('https://formsubmit.co/ajax/62436315cbec0da4baa094393b2a6d7f', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name:     document.getElementById('cf-name').value,
          email:    document.getElementById('cf-email').value,
          subject:  document.getElementById('cf-subject').value,
          message:  document.getElementById('cf-message').value,
          _subject: 'Snap Image Tools — Contact Form',
          _captcha: 'false',
        }),
      });

      const data = await res.json();
      if (data.success) {
        form.style.display   = 'none';
        banner.style.display = 'flex';
      } else {
        throw new Error('FormSubmit rejected');
      }
    } catch {
      errorEl.style.display = 'inline';
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>

<style>
  .page-main { background: var(--site-bg); }
  .page-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }
  .page-header {
    margin-bottom: 48px;
    max-width: 560px;
  }
  .page-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--site-text-muted);
    margin-bottom: 16px;
    font-family: var(--font-mono, ui-monospace, monospace);
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--site-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .page-lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--site-body);
    margin: 0;
  }

  /* Layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 640px) {
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .field-group { display: flex; flex-direction: column; gap: 6px; }
  .field-group label { font-size: 13px; font-weight: 500; color: var(--site-text); }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 10px 12px;
    font-size: 14px;
    font-family: inherit;
    background: var(--site-bg-card);
    border: 1px solid var(--site-border);
    border-radius: 8px;
    color: var(--site-text);
    outline: none;
    transition: border-color 0.15s;
    resize: vertical;
    box-sizing: border-box;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: var(--site-text-muted); }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus { border-color: var(--site-accent); }
  .contact-form select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23888' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 32px;
  }
  .form-footer { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .submit-btn {
    height: 44px;
    padding: 0 24px;
    background: var(--site-text);
    color: var(--site-bg);
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .submit-btn:hover { opacity: 0.85; }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .form-error { font-size: 13px; color: #dc2626; }

  /* Success banner */
  .success-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border: 1px solid #16a34a;
    border-radius: 8px;
    background: #f0fdf4;
    color: #16a34a;
    font-size: 14px;
    font-weight: 500;
  }
  [data-theme="dark"] .success-banner {
    background: #0f1f14;
    border-color: #16a34a;
    color: #4ade80;
  }

  /* Aside */
  .contact-aside { display: flex; flex-direction: column; gap: 12px; }
  .aside-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    border: 1px solid var(--site-border);
    border-radius: 10px;
    background: var(--site-bg-card);
  }
  .aside-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--site-hover);
    color: var(--site-text-muted);
    flex-shrink: 0;
  }
  .aside-title { font-size: 13px; font-weight: 600; color: var(--site-text); margin-bottom: 2px; }
  .aside-body { font-size: 13px; color: var(--site-text-muted); line-height: 1.5; }
  .aside-body a { color: var(--site-accent); text-decoration: none; }
  .aside-body a:hover { text-decoration: underline; }
</style>
