---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ResizeTool from '../components/tools/ResizeTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'What is 200×200 px commonly used for?',
    a: 'This size is standard for forum avatars (phpBB, XenForo, Discourse), comment profile pictures, email signature photos, small app thumbnails, and many older web platforms that cap profile photos at this dimension. It is also a common thumbnail size for product grids in smaller e-commerce stores.',
  },
  {
    q: 'Will a 200×200 px image look blurry on a high-DPI screen?',
    a: 'On retina or high-DPI displays, a 200×200 px image rendered at 100×100 CSS pixels actually looks sharp — each CSS pixel maps to 4 device pixels, giving crisp output. If the platform displays it larger than 200 CSS pixels, it may appear slightly soft, but for typical avatar and thumbnail sizes the quality is excellent.',
  },
  {
    q: 'What format should I use for a 200×200 px avatar?',
    a: 'JPEG for photographic avatars — at 200×200 px a JPEG is typically just 10–20 KB, keeping pages lightweight. If your avatar has a transparent background or is a logo with flat colours, use PNG to preserve sharp edges and transparency. WebP works well for modern web contexts but may not be supported by older platforms.',
  },
  {
    q: 'My image looks stretched after resizing to 200×200 px.',
    a: 'This happens when your original image is not square. To fix it, crop your image to a 1:1 square aspect ratio centred on the subject, then resize to 200×200 px. The easiest approach is to crop to square first, then use this tool to scale to exactly 200×200 px.',
  },
  {
    q: 'Can I use this tool for email signature photos?',
    a: 'Yes. Email signature photos are commonly 100×100 px or 200×200 px. At 200×200 px, a JPEG is tiny (10–20 KB) and loads quickly in email clients. Use JPEG format for the smallest file size, since large images in email signatures cause slow loading and are sometimes flagged as spam.',
  },
  {
    q: 'Is this free and private — is my image uploaded anywhere?',
    a: 'Completely free, no sign-up, and 100% private. Your image is resized entirely in your browser — nothing is sent to any server. This makes it safe to resize profile photos, ID images, or any other personal photos without privacy risk.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/resize-image-to-200x200#app`,
      name: 'Resize Image to 200×200 px Free Online',
      description: 'Resize any image to 200×200 pixels free online. No upload, 100% private. For avatars, profile pictures, forum photos, and email signature images.',
      url: `${siteConfig.domain}/resize-image-to-200x200`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="Resize Image to 200×200 px Free Online"
  description="Free online tool to resize any image to 200×200 pixels. No upload, 100% private. For forum avatars, profile pictures, email signature photos &amp; thumbnails."
  canonical={`${siteConfig.domain}/resize-image-to-200x200`}
  keywords="resize image to 200x200, 200x200 image resizer, avatar resize online, resize photo to 200x200, forum avatar size, email signature photo size"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/resize-image-to-200x200" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>Resize Image to 200×200 px — Free</h1>
        <p class="tool-desc">Free online tool to resize any image to 200×200 pixels. No upload, 100% private. For forum avatars, profile pictures, email signature photos, and small thumbnails.</p>
      </header>

      <ResizeTool width={200} height={200} lockAspect={false} outputFormat="jpeg" presetLabel="200×200 px" />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Resize Image to 200×200 px — For Avatars, Thumbnails &amp; More</h2>
        <p>200×200 pixels is a foundational size on the web — it is the default maximum avatar dimension on forums (phpBB, XenForo, Discourse), comment systems, older CMS platforms, and many enterprise HR portals. At this size, an image file is very lightweight: a JPEG avatar at 200×200 px typically weighs just 10–20 KB, making it negligible in terms of page load impact.</p>
        <p>This size is also used for product thumbnails in smaller online stores, for email signature photos (where large images slow down email delivery and can trigger spam filters), and as a source size for app icons in some frameworks. Resizing a large smartphone photo (12 MP, 5+ MB) to 200×200 px reduces the file size by over 99% while retaining all the visual detail needed for a small avatar or thumbnail.</p>
        <p>For websites that serve images at 2× density for retina screens, a 200×200 px image covers a 100×100 CSS pixel slot at full sharpness. This is ideal for small profile pictures shown alongside usernames in comment threads, forum posts, or leaderboards.</p>
        <p>This tool processes your image entirely in your browser. Nothing is uploaded — the Canvas API draws your image at 200×200 px and re-encodes it in your chosen format. Instant, private, and free.</p>

        <h3>How to Resize to 200×200 px</h3>
        <ol>
          <li><strong>Prepare your image.</strong> For portrait photos used as avatars, crop to a square centred on the face before resizing. A non-square original will appear stretched at 200×200 px if not cropped first.</li>
          <li><strong>Upload your image.</strong> Click "Choose File" or drag and drop. The dimensions are pre-set to 200×200 px with aspect ratio unlocked.</li>
          <li><strong>Choose format.</strong> JPEG for photos (10–20 KB output, fastest loading). PNG for logos or graphics where transparency or sharp lines matter.</li>
          <li><strong>Click "Resize" and download.</strong> Your 200×200 px image is ready to upload as a forum avatar, email signature photo, or thumbnail.</li>
        </ol>

        <h3>Common Use Cases</h3>
        <p><strong>Forum avatars:</strong> Most PHP-based forums (phpBB, XenForo) and community platforms cap avatars at 200×200 px or less. Uploading at exactly 200×200 px avoids the platform's own compression from oversized uploads.</p>
        <p><strong>Email signature photos:</strong> A 200×200 px JPEG at under 20 KB loads quickly in all email clients and does not inflate message size. Large signature images (>100 KB) slow email loading and can affect deliverability.</p>
        <p><strong>HR portals and internal tools:</strong> Many corporate HR systems, project management tools (Jira, Confluence), and CRM platforms use 200×200 px as the recommended profile photo size. Uploading at exactly this size ensures no automatic cropping or quality loss from the platform's resize logic.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/resize-image-to-600x600" class="related-card">
            <span class="related-name">Resize to 600×600</span>
            <span class="related-desc">Social media &amp; e-commerce</span>
          </a>
          <a href="/resize-image-to-passport-size" class="related-card">
            <span class="related-name">Passport Size Photo</span>
            <span class="related-desc">413×531 px / 35×45 mm</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Reduce file size in KB</span>
          </a>
          <a href="/resize-image" class="related-card">
            <span class="related-name">Resize Image</span>
            <span class="related-desc">Any custom pixel dimensions</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
