---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const effectiveDate = 'July 17, 2025';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteConfig.domain}/terms#page`,
  url: `${siteConfig.domain}/terms`,
  name: 'Terms & Conditions — Snap Image Tools',
  description: 'Terms and conditions for using Snap Image Tools, the free browser-based image compressor, resizer, and converter.',
  isPartOf: { '@id': `${siteConfig.domain}/#website` },
};
---

<Layout
  title="Terms &amp; Conditions — Snap Image Tools"
  description="Terms and conditions for using Snap Image Tools — the free browser-based image compressor, resizer, and converter. Read our usage policy, disclaimer, and limitation of liability."
  canonical={`${siteConfig.domain}/terms`}
  keywords="snap image tools terms and conditions, image tools terms of service, image compressor terms"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/terms" />

  <main class="page-main">
    <div class="page-container">

      <div class="page-header">
        <div class="page-tag">Legal</div>
        <h1>Terms &amp; Conditions</h1>
        <p class="page-lead">
          By using Snap Image Tools, you agree to these terms. Please read them before using the service.
        </p>
        <p class="effective-date">Effective date: {effectiveDate}</p>
      </div>

      <div class="prose">

        <h2>1. Acceptance of Terms</h2>
        <p>
          By accessing or using Snap Image Tools at <strong>snapimagetools.com</strong>, you agree to be
          bound by these Terms &amp; Conditions. If you do not agree to these terms, please do not use the service.
        </p>

        <h2>2. Description of Service</h2>
        <p>
          Snap Image Tools provides a suite of free, browser-based image processing tools including image
          compression, resizing, and format conversion. All tools run entirely in your browser — no files
          are uploaded to any server. The service is provided free of charge and requires no registration
          or personal information.
        </p>

        <h2>3. Permitted Use</h2>
        <p>
          Snap Image Tools is provided for personal, educational, and professional use. You may process
          any images you own or have the right to process. You may not:
        </p>
        <ul>
          <li>Attempt to reverse-engineer, decompile, or extract the source code for commercial redistribution</li>
          <li>Use automated tools to scrape or excessively load the service</li>
          <li>Use the service to process images that infringe third-party intellectual property rights</li>
          <li>Use the service in any way that violates applicable laws or regulations</li>
        </ul>

        <h2>4. Image Processing &amp; Output Quality</h2>
        <p>
          Snap Image Tools uses the HTML5 Canvas API to process images entirely within your browser.
          The quality of compressed, resized, or converted output depends on:
        </p>
        <ul>
          <li>The quality and format of your source image</li>
          <li>The quality settings and target size you select</li>
          <li>Your browser's implementation of the Canvas API and supported codecs</li>
        </ul>
        <p>
          While we strive to provide the best possible output quality, <strong>we cannot guarantee
          specific results for all images and settings.</strong> For government exam portals with strict
          KB requirements, we recommend verifying the output file size before submission.
        </p>

        <h2>5. Disclaimer of Warranties</h2>
        <p>
          Snap Image Tools is provided <strong>"as is"</strong> and <strong>"as available"</strong> without
          warranties of any kind, either express or implied, including but not limited to implied warranties
          of merchantability, fitness for a particular purpose, or non-infringement.
        </p>
        <p>
          We do not warrant that the service will be uninterrupted, error-free, or free of viruses or
          other harmful components. Browser compatibility and Canvas API support varies across devices and
          browser versions.
        </p>

        <h2>6. Limitation of Liability</h2>
        <p>
          To the fullest extent permitted by applicable law, Snap Image Tools and its operators shall not
          be liable for any indirect, incidental, special, consequential, or punitive damages arising from
          your use of the service, including but not limited to loss of image data, failed exam submissions
          due to incorrect file size, or reliance on results provided by the tools.
        </p>

        <h2>7. Intellectual Property</h2>
        <p>
          The Snap Image Tools name, logo, design, and source code are the intellectual property of their
          respective owners. You may not reproduce, distribute, or create derivative works without prior
          written permission, except as permitted by applicable law (e.g., fair use for educational or
          editorial purposes).
        </p>
        <p>
          You retain full ownership of any images you process using Snap Image Tools. We claim no rights
          over images processed through the service.
        </p>

        <h2>8. Third-Party Services</h2>
        <p>
          Snap Image Tools integrates several third-party services, each governed by their own terms and policies:
        </p>
        <ul>
          <li>
            <strong>Google AdSense</strong> — serves advertisements on this site. By using Snap Image Tools you
            may be shown ads delivered by Google and its partners. Google's use of advertising cookies is
            governed by <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's Privacy Policy</a>.
          </li>
          <li>
            <strong>Google Analytics</strong> — collects anonymised usage data (page views, device type, country)
            to help us understand how the tools are used. No personally identifiable information is collected.
          </li>
          <li>
            <strong>FormSubmit.co</strong> — processes contact form submissions. Messages sent via the contact
            form are handled by FormSubmit.co and forwarded to us by email.
          </li>
        </ul>
        <p>
          We are not responsible for the content or practices of any third-party services. Their respective
          terms and privacy policies apply to your use of those services.
        </p>

        <h2>9. Changes to Terms</h2>
        <p>
          We reserve the right to update these Terms &amp; Conditions at any time. The effective date at
          the top of this page will be updated accordingly. Continued use of Snap Image Tools after changes
          are posted constitutes your acceptance of the new terms.
        </p>

        <h2>10. Governing Law</h2>
        <p>
          These terms are governed by and construed in accordance with applicable law. Any disputes arising
          under these terms shall be resolved in the applicable courts.
        </p>

        <h2>11. Contact</h2>
        <p>
          If you have any questions about these Terms &amp; Conditions, please <a href="/contact">contact us</a>.
        </p>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    background: var(--site-bg);
  }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }
  .page-header {
    margin-bottom: 48px;
  }
  .page-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--site-text-muted);
    margin-bottom: 16px;
    font-family: var(--font-mono, ui-monospace, monospace);
  }
  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--site-text);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .page-lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--site-body);
    margin: 0 0 8px;
    max-width: 560px;
  }
  .effective-date {
    font-size: 0.8125rem;
    color: var(--site-text-muted);
    font-family: var(--font-mono, ui-monospace, monospace);
    margin: 0;
  }
  .prose h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--site-text);
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .prose p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin: 0 0 1rem;
  }
  .prose ul {
    padding-left: 1.5rem;
    margin: 0.5rem 0 1rem;
  }
  .prose li {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--site-body);
    margin-bottom: 0.5rem;
  }
  .prose strong { color: var(--site-text); font-weight: 600; }
  .prose a { color: var(--site-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { opacity: 0.8; }
</style>
