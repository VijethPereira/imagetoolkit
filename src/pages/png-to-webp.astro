---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Does WebP support transparency like PNG?',
    a: 'Yes. WebP fully supports alpha-channel transparency, just like PNG. When you convert a PNG with a transparent background to WebP, the transparency is perfectly preserved in the output file. This makes WebP an excellent replacement for PNG on modern websites where transparency is needed.',
  },
  {
    q: 'How much smaller is WebP compared to PNG?',
    a: 'WebP lossless compression is approximately 26% smaller than PNG for the same image. WebP lossy compression is even more efficient — often 60–80% smaller than the equivalent PNG for photographs, though with some quality reduction. For logos and flat-colour graphics, use lossless WebP (quality 100) to get a smaller file without any quality loss.',
  },
  {
    q: 'When should I keep PNG instead of converting to WebP?',
    a: 'Keep PNG when: the file will be re-edited and re-saved many times (PNG is lossless so every save is identical, unlike re-encoding lossy WebP); you need to upload to a platform that does not support WebP; or you need compatibility with older image editors or software that cannot open WebP files.',
  },
  {
    q: 'Will my PNG logo look the same after converting to WebP lossless?',
    a: 'Yes, if you use quality 100 (lossless WebP), the output is pixel-perfect and identical to the source PNG. For logos and flat-colour graphics, lossless WebP gives a smaller file with zero quality difference. In lossy mode, flat-colour graphics may show slight colour banding at lower quality settings — use lossless mode for logos.',
  },
  {
    q: 'Do I need to change my HTML after converting PNG to WebP?',
    a: 'Yes — update the src attribute in your <img> tags (or your CSS background-image URLs) to point to the .webp file. You can also use a <picture> element with a WebP source and a PNG fallback if you need to support older browsers, but for modern sites simply replacing the PNG with WebP works perfectly.',
  },
  {
    q: 'Is this free and does it upload my PNG anywhere?',
    a: 'Completely free with no account required. All conversion happens in your browser using the Canvas API — your PNG is never uploaded to any server. Conversion is instant and 100% private.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/png-to-webp#app`,
      name: 'PNG to WebP Converter Online Free',
      description: 'Convert PNG to WebP online free. WebP is 26% smaller than PNG and supports transparency. No upload, 100% private. For faster websites and smaller images.',
      url: `${siteConfig.domain}/png-to-webp`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="PNG to WebP Converter — Free Online"
  description="Free PNG to WebP converter online. WebP is 26% smaller than PNG and supports transparency. No upload, 100% private. Faster websites with smaller images."
  canonical={`${siteConfig.domain}/png-to-webp`}
  keywords="png to webp, convert png to webp, png webp converter online, png to webp free, reduce png size"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/png-to-webp" />
  <main class="page-main">
    <div class="tool-screen"><div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>PNG to WebP Converter — Free</h1>
        <p class="tool-desc">Convert PNG images to WebP format free online. WebP is 26% smaller than PNG and supports transparency. No upload, 100% private.</p>
      </header>

      <ConvertTool from="PNG" to="webp" />

    </div></div>
    <div class="page-spacer" aria-hidden="true"></div>
    <div class="page-content"><div class="container">
      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>Convert PNG to WebP — Smaller Files, Preserved Transparency</h2>
        <p>PNG has been the standard for lossless web images with transparency since the late 1990s. While it produces perfect-quality images, PNG files can be very large — especially for photographs and complex graphics. WebP was designed by Google as a modern successor that is smaller, faster to load, and supports the same alpha-channel transparency that makes PNG essential for logos, icons, and overlays.</p>
        <p>WebP lossless compression is approximately 26% smaller than PNG for the same image content. For photographs stored as PNG (common for screenshots and design exports), WebP lossy compression achieves reductions of 60–80% while maintaining excellent visual quality. Every kilobyte saved translates to faster page loads and a better user experience — particularly for mobile users on slower connections where large PNG files create noticeable delays.</p>
        <p>Modern browsers — Chrome, Firefox, Safari 14+, Edge, and all current mobile browsers — natively support WebP. If your web project targets modern browsers, replacing PNG with WebP is a straightforward and impactful optimisation. The transparency in your PNG is automatically preserved in the WebP output, making the format swap seamless for logos, icons, and images with transparent backgrounds.</p>
        <p>This converter runs entirely in your browser. Your PNG is drawn onto an HTML5 Canvas and re-encoded as WebP using the browser's native encoder. Nothing is uploaded to any server — instant and completely private.</p>

        <h3>How to Convert PNG to WebP</h3>
        <ol>
          <li><strong>Upload your PNG.</strong> Click "Choose File" or drag and drop. Transparency (alpha channel) is automatically handled.</li>
          <li><strong>Set quality.</strong> Use 100 for lossless (pixel-perfect, same quality as PNG but smaller). Use 80–90 for lossy (significantly smaller, excellent for most use cases). Use lower values for maximum size reduction on photographs stored as PNG.</li>
          <li><strong>Convert and compare.</strong> Click "Convert" to see the before/after size comparison.</li>
          <li><strong>Download the WebP.</strong> Replace the PNG reference in your HTML/CSS with the .webp file path.</li>
        </ol>

        <h3>Lossless vs Lossy WebP for PNG Conversion</h3>
        <p><strong>Lossless WebP (quality 100):</strong> Pixel-perfect conversion — identical quality to the source PNG, but ~26% smaller. Ideal for logos, icons, diagrams, and graphics where colour accuracy matters.</p>
        <p><strong>Lossy WebP (quality 80):</strong> Much smaller file. For photographs saved as PNG (screenshots of photos, design mockups with photos), lossy WebP at 80% quality can be 60–80% smaller than the PNG with imperceptible visual difference.</p>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="related-section">
        <h2>Related Tools</h2>
        <div class="related-grid">
          <a href="/jpg-to-webp" class="related-card">
            <span class="related-name">JPG to WebP</span>
            <span class="related-desc">25–34% smaller than JPEG</span>
          </a>
          <a href="/webp-to-png" class="related-card">
            <span class="related-name">WebP to PNG</span>
            <span class="related-desc">Convert back to PNG</span>
          </a>
          <a href="/png-to-jpg" class="related-card">
            <span class="related-name">PNG to JPG</span>
            <span class="related-desc">Smallest file for photos</span>
          </a>
          <a href="/compress-image" class="related-card">
            <span class="related-name">Compress Image</span>
            <span class="related-desc">Reduce size in KB</span>
          </a>
        </div>
      </section>
    </div></div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 0; }
  .tool-screen { position: fixed; top: 64px; left: 0; right: 0; height: calc(100vh - 64px); overflow-y: auto; background: var(--site-bg); z-index: 1; padding: 2rem 0 1.5rem; }
  .page-spacer { height: 100vh; }
  .page-content { position: relative; z-index: 2; background: var(--site-bg); padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600; letter-spacing: -1.28px; color: var(--site-text); line-height: 1.15; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-body); margin: 0; max-width: 64ch; line-height: 1.6; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-body); margin: 0 0 1rem; max-width: 72ch; line-height: 1.6; }
  .content-section ol { color: var(--site-body); padding-left: 1.5rem; max-width: 64ch; margin: 0 0 1rem; }
  .content-section li { margin-bottom: 0.5rem; line-height: 1.6; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.96px; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
  .related-section { margin: 2rem 0; }
  .related-section h2 { font-size: 1.25rem; font-weight: 600; letter-spacing: -0.6px; color: var(--site-text); margin: 0 0 0.875rem; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(175px, 1fr)); gap: 0.625rem; }
  .related-card { display: block; padding: 0.875rem 1rem; border: 1px solid var(--site-border); border-radius: 8px; text-decoration: none; background: var(--site-bg-card); transition: box-shadow 0.15s, border-color 0.15s; }
  .related-card:hover { box-shadow: var(--shadow-2); border-color: var(--site-border-strong); text-decoration: none; }
  .related-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--site-text); margin-bottom: 0.2rem; }
  .related-desc { display: block; font-size: 0.75rem; color: var(--site-text-muted); line-height: 1.4; }

  @media (max-width: 640px) {
    .page-content { padding: 1.5rem 0 3rem; }
    h1 { letter-spacing: -0.5px; }
    .content-section h2, .faq-section h2 { letter-spacing: -0.4px; }
    .content-section { margin: 1.75rem 0; }
    .faq-section { margin: 1.75rem 0; }
  }
</style>
