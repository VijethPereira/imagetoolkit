---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import ConvertTool from '../components/tools/ConvertTool.astro';
import siteConfig from '../site.config.ts';

const faqs = [
  {
    q: 'Why convert WebP to PNG instead of JPEG?',
    a: 'Choose PNG when you need to preserve transparency — PNG fully supports alpha channels, just like WebP. Also choose PNG when you need a lossless copy for editing: PNG is lossless so it can be re-saved many times without quality degradation, while JPEG loses quality with each re-encode. PNG also has better compatibility with older image editors and design tools that may not support WebP.',
  },
  {
    q: 'Will the PNG file be larger than the original WebP?',
    a: 'Yes, in almost all cases. WebP uses more efficient compression than PNG. Converting WebP to PNG will produce a larger file — often significantly larger for photographs. If file size is a concern, consider keeping the WebP for web use or converting to JPEG instead. PNG is best when quality and transparency preservation matter more than file size.',
  },
  {
    q: 'Can I open the converted PNG in Photoshop or Illustrator?',
    a: 'Yes. PNG is one of the most universally supported image formats and can be opened in Photoshop, Illustrator, GIMP, Paint.NET, Affinity Photo, and virtually every image editor. This is one of the main reasons to convert WebP to PNG — for use in design and editing workflows where WebP may not be natively supported.',
  },
  {
    q: 'Does converting WebP to PNG affect image quality?',
    a: 'Converting WebP lossless to PNG is completely lossless — the pixel values are identical. Converting WebP lossy to PNG produces a lossless PNG of the already-decompressed WebP, so no further quality loss occurs during conversion, but the original lossy compression artefacts from the WebP encoding are preserved. You cannot recover quality lost during the original WebP encoding.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      '@id': `${siteConfig.domain}/webp-to-png#app`,
      name: `WebP to PNG Converter — ${siteConfig.siteName}`,
      description: 'Convert WebP to PNG online free. Preserve transparency and get a lossless, universally supported image.',
      url: `${siteConfig.domain}/webp-to-png`,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};
---

<Layout
  title="WebP to PNG Converter Online — Free"
  description="Convert WebP to PNG online free. Preserve transparency and get a lossless, universally supported image."
  canonical={`${siteConfig.domain}/webp-to-png`}
  keywords="webp to png, convert webp to png, webp png converter"
  jsonLd={jsonLd}
>
  <SiteNav currentPath="/webp-to-png" />
  <main class="page-main">
    <div class="container">
      <header class="tool-header">
        <a href="/" class="back-link">&larr; All tools</a>
        <h1>WebP to PNG Converter</h1>
        <p class="tool-desc">Convert WebP to PNG online free. Preserve transparency and get a lossless, universally supported image.</p>
      </header>

      <ConvertTool from="WebP" to="png" />

      <AdSlot slot="1111111111" />

      <section class="content-section">
        <h2>About This Tool</h2>
        <p>WebP is widely used on modern websites but is not as universally compatible as PNG in design workflows and offline software. If you downloaded a WebP image (such as a logo, icon, or graphic with a transparent background) and need to use it in a design project, converting to PNG gives you the broadest compatibility. PNG is supported natively in every major image editor, presentation tool, and document processor.</p>
        <p>The key advantage of converting to PNG rather than JPEG is transparency preservation. WebP supports alpha-channel transparency, and so does PNG. When you convert a WebP logo with a transparent background to PNG, the transparency is maintained perfectly. If you converted that same WebP to JPEG, the transparent areas would become white — which is usually not what you want for logos or overlays.</p>
        <p>PNG is also a lossless format, which makes it ideal for images that will be edited further. Once you have a PNG, you can open it, make changes, and save it again without any quality degradation — unlike JPEG which re-compresses (and loses quality) every time you save. For web delivery, PNG files are larger than WebP, but for editing and archival purposes, PNG is the right choice.</p>
        <h3>How to Use</h3>
        <ol>
          <li>Click "Choose File" or drag and drop your WebP image onto the tool.</li>
          <li>PNG output is pre-selected — no format adjustment needed.</li>
          <li>Click "Convert" — transparency in the WebP is automatically preserved.</li>
          <li>Download the PNG file and open it in your preferred image editor or application.</li>
        </ol>
      </section>

      <AdSlot slot="2222222222" />

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">
                <button type="button" aria-expanded="false" class="faq-toggle">
                  {q}<span class="faq-icon" aria-hidden="true">+</span>
                </button>
              </dt>
              <dd class="faq-a" hidden><p>{a}</p></dd>
            </div>
          ))}
        </dl>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      var dd = btn.closest('.faq-item').querySelector('.faq-a');
      var icon = btn.querySelector('.faq-icon');
      dd.hidden = expanded;
      if (icon) icon.textContent = expanded ? '+' : '−';
    });
  });
</script>

<style>
  .page-main { padding: 2rem 0 4rem; }
  .container { max-width: 860px; margin-inline: auto; padding-inline: 1.5rem; }
  .tool-header { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--site-text-muted); text-decoration: none; margin-bottom: 1rem; transition: color 0.15s; }
  .back-link:hover { color: var(--site-text); text-decoration: none; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: var(--site-text); line-height: 1.2; margin: 0 0 0.75rem; }
  .tool-desc { font-size: 1.0625rem; color: var(--site-text-muted); margin: 0; max-width: 64ch; }
  .content-section { margin: 2.5rem 0; }
  .content-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 0.75rem; }
  .content-section h3 { font-size: 1.125rem; font-weight: 600; color: var(--site-text); margin: 1.75rem 0 0.5rem; }
  .content-section p { color: var(--site-text-muted); margin: 0 0 1rem; max-width: 72ch; }
  .content-section ol { color: var(--site-text-muted); padding-left: 1.5rem; max-width: 64ch; }
  .content-section li { margin-bottom: 0.375rem; }
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.375rem; font-weight: 700; color: var(--site-text); margin: 0 0 1.25rem; }
  .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .faq-item { border: 1px solid var(--site-border); border-radius: 8px; overflow: hidden; }
  .faq-toggle { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--site-bg-card); border: none; color: var(--site-text); font-size: 0.9375rem; font-weight: 600; text-align: left; cursor: pointer; transition: background 0.15s; }
  .faq-toggle:hover { background: var(--site-hover); }
  .faq-icon { font-size: 1.25rem; line-height: 1; flex-shrink: 0; color: var(--site-text-muted); }
  .faq-a { margin: 0; padding: 0 1.25rem 1rem; background: var(--site-bg-card); }
  .faq-a p { margin: 0; font-size: 0.9375rem; color: var(--site-text-muted); line-height: 1.6; }
</style>
