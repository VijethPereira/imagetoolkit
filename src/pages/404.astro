---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';
---

<Layout
  title="Page Not Found — Image Tools"
  description="The page you're looking for doesn't exist."
>
  <SiteNav />

  <main class="page-main">
    <div class="container">
      <p class="code">404</p>
      <h1>Page Not Found</h1>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="home-link">&#8592; Back to {siteConfig.siteName}</a>
      <p class="suggestion">Looking for a specific tool? Try one of these:</p>
      <ul class="tool-list">
        <li><a href="/compress-image">Compress Image</a></li>
        <li><a href="/resize-image-to-passport-size">Passport Size Photo</a></li>
        <li><a href="/compress-image-to-50kb">Compress to 50 KB</a></li>
        <li><a href="/signature-resizer-for-ssc">SSC Signature Resizer</a></li>
        <li><a href="/jpg-to-webp">JPG to WebP</a></li>
      </ul>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .page-main {
    padding: 6rem 0;
    text-align: center;
  }

  .container {
    max-width: 560px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .code {
    font-size: 5rem;
    font-weight: 800;
    color: var(--site-border);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--site-text);
    margin: 0 0 0.75rem;
  }

  p {
    color: var(--site-text-muted);
    margin: 0 0 1.5rem;
  }

  .home-link {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    background: var(--site-accent);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
    margin-bottom: 2.5rem;
  }

  .home-link:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .suggestion {
    font-size: 0.875rem;
    color: var(--site-text-muted);
    margin: 0 0 0.75rem;
  }

  .tool-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .tool-list a {
    color: var(--site-accent);
    font-size: 0.9375rem;
    text-decoration: none;
  }

  .tool-list a:hover {
    text-decoration: underline;
  }
</style>
