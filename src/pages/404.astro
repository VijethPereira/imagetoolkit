---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../site.config.ts';

const suggestions = [
  { label: 'Compress Image', href: '/compress-image' },
  { label: 'Passport Size Photo', href: '/resize-image-to-passport-size' },
  { label: 'Compress to 50 KB', href: '/compress-image-to-50kb' },
  { label: 'SSC Signature Resize', href: '/signature-resizer-for-ssc' },
  { label: 'JPG to WebP', href: '/jpg-to-webp' },
  { label: 'PNG to JPG', href: '/png-to-jpg' },
];
---

<Layout
  title={`404 — Page Not Found | ${siteConfig.siteName}`}
  description="The page you're looking for doesn't exist or has been moved."
>
  <SiteNav />

  <main class="error-main">
    <div class="error-card">
      <div class="error-visual">
        <svg class="icon-ghost" viewBox="0 0 80 80" fill="none" aria-hidden="true">
          <circle cx="40" cy="34" r="26" fill="var(--site-accent-soft)" stroke="var(--site-accent)" stroke-width="2"/>
          <circle cx="32" cy="30" r="3.5" fill="var(--site-accent)"/>
          <circle cx="48" cy="30" r="3.5" fill="var(--site-accent)"/>
          <path d="M32 42 Q40 50 48 42" stroke="var(--site-accent)" stroke-width="2" stroke-linecap="round" fill="none"/>
          <path d="M14 60 Q14 56 18 56 Q22 56 22 52 Q22 56 26 56 Q30 56 30 60 Q30 56 34 56 Q38 56 38 52 Q38 56 42 56 Q46 56 46 60 Q46 56 50 56 Q54 56 54 52 Q54 56 58 56 Q62 56 62 60 L62 72 Q62 76 58 76 Q54 76 54 72 Q54 76 50 76 Q46 76 46 72 Q46 76 42 76 Q38 76 38 72 Q38 76 34 76 Q30 76 30 72 Q30 76 26 76 Q22 76 22 72 Q22 76 18 76 Q14 76 14 72 Z" fill="var(--site-accent-soft)" stroke="var(--site-accent)" stroke-width="2"/>
        </svg>
        <p class="error-code">404</p>
      </div>

      <h1>Page Not Found</h1>
      <p class="error-desc">This page seems to have vanished into thin air. It may have been moved, renamed, or never existed.</p>

      <a href="/" class="btn-home">&#8592; Back to {siteConfig.siteName}</a>

      <div class="divider"></div>

      <p class="suggestions-label">Looking for a tool? Try one of these:</p>
      <div class="chip-grid">
        {suggestions.map((s) => (
          <a href={s.href} class="chip">{s.label}</a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .error-main {
    min-height: calc(100dvh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
  }

  .error-card {
    max-width: 560px;
    width: 100%;
    text-align: center;
    background: var(--site-bg-card);
    border: 1px solid var(--site-border);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    box-shadow: var(--shadow-3);
  }

  .error-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .icon-ghost {
    width: 52px;
    height: 52px;
  }

  .error-code {
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    margin: 0;
    background: linear-gradient(135deg, var(--site-accent) 0%, #7c3aed 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -2px;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--site-text);
    margin: 0 0 0.625rem;
  }

  .error-desc {
    color: var(--site-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.5rem;
    background: var(--site-accent);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 0.15s;
    margin-bottom: 2rem;
  }

  .btn-home:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .divider {
    height: 1px;
    background: var(--site-border);
    margin-bottom: 1.5rem;
  }

  .suggestions-label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--site-text-muted);
    margin: 0 0 0.875rem;
  }

  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .chip {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: var(--site-bg-soft2);
    color: var(--site-accent);
    border: 1px solid var(--site-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.12s, border-color 0.12s;
  }

  .chip:hover {
    background: var(--site-accent-soft);
    border-color: var(--site-accent);
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .error-card {
      padding: 2rem 1.25rem;
    }

    .error-code {
      font-size: 4rem;
    }
  }
</style>
