---
import siteConfig from '../site.config.ts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="brand">{siteConfig.siteName}</p>
    <nav aria-label="Footer navigation">
      <ul class="footer-links">
        {siteConfig.navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="sister-site">
      <span class="sister-label">Also try:</span>
      <a href="https://quickmeasuretool.com" class="sister-link" target="_blank" rel="noopener">
        Quick Measure Tool — free online ruler & measurement tools
      </a>
    </div>
    <p class="copy">&copy; {year} {siteConfig.siteName}. All rights reserved.</p>
  </div>
</footer>

<style>
  /* footer — DESIGN: canvas bg, hairline top border, 48px padding */
  .site-footer {
    position: relative;
    z-index: 3;
    border-top: 1px solid var(--site-border);
    background: var(--site-bg-card);
    padding: 3rem 0;
  }

  .footer-inner {
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    text-align: center;
  }

  /* Brand — body-sm-strong: 14px/600, negative tracking */
  .brand {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.3px;
    color: var(--site-text);
    margin: 0;
  }

  /* footer links — body-sm: 14px/400, body color */
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem 1.25rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: var(--site-body);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover {
    color: var(--site-text);
    text-decoration: none;
  }

  /* banner-marketing pill — DESIGN: canvas-soft bg, full pill, body-sm */
  .sister-site {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
    padding: 0.375rem 1rem;
    background: var(--site-hover);
    border-radius: 9999px;
    font-size: 0.8125rem;
  }
  .sister-label { color: var(--site-text-muted); flex-shrink: 0; }
  .sister-link {
    color: var(--site-accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .sister-link:hover { opacity: 0.75; text-decoration: none; }

  /* caption — 12px, muted */
  .copy {
    font-size: 0.75rem;
    color: var(--site-text-muted);
    margin: 0;
  }
</style>
