---
interface Props {
  from?: string;           // source format label e.g. 'JPG'
  to?: string;             // target format: 'jpeg' | 'png' | 'webp'
  quality?: number;        // default 0.92
  filterMode?: 'grayscale' | 'bw';  // canvas filter applied before encoding
}
const { from, to, quality = 0.92, filterMode } = Astro.props;
---

<section
  class="tool-widget"
  id="convert-tool"
  data-to={to ?? ''}
  data-quality={quality.toString()}
  data-filter-mode={filterMode ?? ''}
>
  <div class="drop-zone" id="drop-zone" role="button" tabindex="0" aria-label="Upload image">
    <div class="drop-inner">
      <svg class="drop-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
      </svg>
      <p class="drop-label">
        Drop {from ? `your ${from} image` : 'image'} here or <span class="drop-link">browse</span>
      </p>
      <p class="drop-hint">JPG · PNG · WebP — max 20 MB</p>
    </div>
    <div class="preview-wrap" id="preview-wrap" hidden>
      <img id="preview-img" class="preview-img" alt="" />
      <p class="preview-hint">Click to change image</p>
    </div>
    <input type="file" id="file-input" accept="image/*" class="file-input" />
  </div>

  <div class="controls" id="controls" hidden>
    <div class="file-meta">
      <span class="file-name" id="file-name"></span>
      <span class="file-size" id="orig-size"></span>
      <button class="change-btn" id="change-btn" type="button">× Change</button>
    </div>

    {!to && (
      <div class="format-row">
        <label for="fmt-select">Convert to</label>
        <select id="fmt-select" class="fmt-select">
          <option value="webp">WebP</option>
          <option value="jpeg">JPEG</option>
          <option value="png">PNG</option>
        </select>
      </div>
    )}

    {to && (
      <p class="convert-note">Converting to: <strong>{to.toUpperCase()}</strong></p>
    )}

    <div class="quality-row">
      <label for="quality-slider">Quality</label>
      <input type="range" id="quality-slider" min="1" max="99" value={Math.round(quality * 100)} class="slider" />
      <span class="quality-val" id="quality-val">{Math.round(quality * 100)}%</span>
    </div>

    <button class="btn-primary" id="convert-btn">
      {filterMode === 'grayscale' ? 'Convert to Grayscale' : filterMode === 'bw' ? 'Convert to Black & White' : to ? `Convert to ${to.toUpperCase()}` : 'Convert Image'}
    </button>
  </div>

  <p class="status" id="status" hidden></p>

  <div class="result" id="result" hidden>
    <div class="result-stats">
      <div class="stat"><span class="stat-label">Original</span><span class="stat-val" id="r-orig"></span></div>
      <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      <div class="stat"><span class="stat-label">Converted</span><span class="stat-val green" id="r-new"></span></div>
    </div>
    <div class="result-actions">
      <a class="btn-primary" id="download-btn" download>Download</a>
      <button class="btn-ghost" id="reset-btn">Try another image</button>
    </div>
  </div>

  <p class="privacy-note">
    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd"/></svg>
    Your image never leaves your device.
  </p>
</section>

<script>
  const tool = document.getElementById('convert-tool') as HTMLElement;
  const dropZone = document.getElementById('drop-zone') as HTMLElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const controls = document.getElementById('controls') as HTMLElement;
  const fileNameEl = document.getElementById('file-name') as HTMLElement;
  const origSize = document.getElementById('orig-size') as HTMLElement;
  const fmtSelect = document.getElementById('fmt-select') as HTMLSelectElement;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityVal = document.getElementById('quality-val') as HTMLElement;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('status') as HTMLElement;
  const resultEl = document.getElementById('result') as HTMLElement;
  const rOrig = document.getElementById('r-orig') as HTMLElement;
  const rNew = document.getElementById('r-new') as HTMLElement;
  const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const changeBtn = document.getElementById('change-btn') as HTMLButtonElement;

  const previewWrap = document.getElementById('preview-wrap') as HTMLElement;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const dropInner = dropZone.querySelector('.drop-inner') as HTMLElement;

  const presetTo    = tool.dataset.to || null;
  const filterMode  = tool.dataset.filterMode || '';
  let currentFile: File | null = null;
  let previewUrl: string | null = null;

  function fmtBytes(b: number) {
    if (b < 1024) return `${b} B`;
    if (b < 1024 * 1024) return `${(b / 1024).toFixed(1)} KB`;
    return `${(b / (1024 * 1024)).toFixed(2)} MB`;
  }
  function setStatus(msg: string) { statusEl.textContent = msg; statusEl.hidden = !msg; }

  function loadImage(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = URL.createObjectURL(file);
    });
  }

  function showControls(file: File) {
    currentFile = file;
    fileNameEl.textContent = file.name;
    origSize.textContent = fmtBytes(file.size);
    controls.hidden = false;
    resultEl.hidden = true;
    setStatus('');
    if (previewUrl) URL.revokeObjectURL(previewUrl);
    previewUrl = URL.createObjectURL(file);
    previewImg.src = previewUrl;
    previewWrap.hidden = false;
    dropInner.hidden = true;
  }

  dropZone.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const f = e.dataTransfer?.files[0];
    if (f && f.type.startsWith('image/')) showControls(f);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) showControls(fileInput.files[0]);
  });

  qualitySlider.addEventListener('input', () => {
    qualityVal.textContent = `${qualitySlider.value}%`;
  });

  convertBtn.addEventListener('click', async () => {
    if (!currentFile) return;
    convertBtn.disabled = true;
    setStatus('Converting…');
    resultEl.hidden = true;

    try {
      const img = await loadImage(currentFile);
      const fmt = presetTo || fmtSelect?.value || 'webp';
      const mime = `image/${fmt}`;
      const quality = parseInt(qualitySlider.value) / 100;

      const canvas = document.createElement('canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;
      const ctx = canvas.getContext('2d')!;
      if (fmt === 'jpeg') { ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, canvas.width, canvas.height); }
      if (filterMode === 'grayscale') ctx.filter = 'grayscale(1)';
      if (filterMode === 'bw')        ctx.filter = 'grayscale(1) contrast(500%)';
      ctx.drawImage(img, 0, 0);
      ctx.filter = 'none';

      const blob = await new Promise<Blob>((res, rej) => {
        canvas.toBlob((b) => b ? res(b) : rej(new Error('failed')), mime, quality);
      });

      rOrig.textContent = fmtBytes(currentFile.size);
      rNew.textContent = fmtBytes(blob.size);

      const ext = fmt === 'jpeg' ? 'jpg' : fmt;
      const base = currentFile.name.replace(/\.[^.]+$/, '');
      downloadBtn.href = URL.createObjectURL(blob);
      downloadBtn.download = `${base}.${ext}`;

      controls.hidden = true;
      resultEl.hidden = false;
      setStatus('');
    } catch {
      setStatus('Something went wrong. Please try a different image.');
    }
    convertBtn.disabled = false;
  });

  function reset() {
    currentFile = null;
    fileInput.value = '';
    controls.hidden = true;
    resultEl.hidden = true;
    setStatus('');
    if (previewUrl) { URL.revokeObjectURL(previewUrl); previewUrl = null; }
    previewImg.src = '';
    previewWrap.hidden = true;
    dropInner.hidden = false;
  }

  resetBtn.addEventListener('click', reset);
  changeBtn.addEventListener('click', reset);
</script>

<style>
  .tool-widget { background: var(--site-bg-card); border-radius: 12px; box-shadow: var(--shadow-4); padding: 2rem; margin: 1.5rem 0 2rem; }
  .drop-zone { border: 2px dashed var(--site-border); border-radius: 8px; padding: 2.5rem 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.15s, background 0.15s; position: relative; }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--site-accent); background: color-mix(in srgb, var(--site-accent) 5%, transparent); }
  .drop-inner { pointer-events: none; }
  .drop-icon { width: 2.5rem; height: 2.5rem; color: var(--site-text-muted); margin: 0 auto 0.75rem; }
  .drop-label { font-size: 1rem; font-weight: 500; color: var(--site-text); margin: 0 0 0.25rem; }
  .drop-link { color: var(--site-accent); }
  .drop-hint { font-size: 0.8125rem; color: var(--site-text-muted); margin: 0; }
  .file-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }

  .preview-wrap { pointer-events: none; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .preview-img { max-width: 100%; max-height: 200px; border-radius: 6px; object-fit: contain; display: block; }
  .preview-hint { font-size: 0.8125rem; color: var(--site-text-muted); margin: 0; }
  .controls { margin-top: 1.25rem; }
  .file-meta { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 1rem; padding: 0.75rem 1rem; background: var(--site-hover); border-radius: 8px; flex-wrap: wrap; }
  .file-name { font-weight: 600; color: var(--site-text); font-size: 0.9375rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 18ch; }
  .file-size { font-size: 0.875rem; color: var(--site-text-muted); flex-shrink: 0; }
  .change-btn { margin-left: auto; background: none; border: none; font-size: 0.8125rem; color: var(--site-text-muted); cursor: pointer; padding: 0.125rem 0.375rem; border-radius: 4px; flex-shrink: 0; transition: color 0.15s, background 0.15s; }
  .change-btn:hover { color: var(--site-text); background: var(--site-border); }
  .convert-note { margin: 0 0 1rem; color: var(--site-text-muted); font-size: 0.9375rem; }
  .format-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 0.9375rem; color: var(--site-text); }
  .fmt-select { padding: 0.375rem 0.75rem; border: 1px solid var(--site-border); border-radius: 6px; background: var(--site-bg); color: var(--site-text); font-size: 0.9375rem; }
  .quality-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 0.9375rem; color: var(--site-text); }
  .slider { flex: 1; accent-color: var(--site-accent); }
  .quality-val { font-weight: 600; min-width: 3ch; color: var(--site-accent); }
  .btn-primary { display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.5rem; background: var(--site-accent); color: #fff; border: none; border-radius: 9999px; font-size: 0.9375rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: opacity 0.15s; width: 100%; }
  .btn-primary:hover { opacity: 0.85; text-decoration: none; }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-ghost { display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.5rem; border: 1px solid var(--site-border); border-radius: 9999px; background: transparent; color: var(--site-body); font-size: 0.9375rem; cursor: pointer; width: 100%; transition: background 0.15s, color 0.15s, border-color 0.15s; }
  .btn-ghost:hover { background: var(--site-hover); color: var(--site-text); border-color: var(--site-border-strong); }
  .status { text-align: center; color: var(--site-text-muted); font-size: 0.9375rem; margin: 0.75rem 0 0; padding: 0.75rem; background: var(--site-hover); border-radius: 8px; }
  .result { margin-top: 1.25rem; }
  .result-stats { display: flex; align-items: center; gap: 1rem; padding: 1rem; background: color-mix(in srgb, #22c55e 8%, transparent); border: 1px solid color-mix(in srgb, #22c55e 30%, transparent); border-radius: 10px; margin-bottom: 1rem; flex-wrap: wrap; justify-content: center; }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  .stat-label { font-size: 0.75rem; color: var(--site-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .stat-val { font-size: 1.125rem; font-weight: 700; color: var(--site-text); }
  .stat-val.green { color: #16a34a; }
  [data-theme="dark"] .stat-val.green { color: #4ade80; }
  .arrow-icon { width: 1.25rem; color: var(--site-text-muted); }
  .result-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .privacy-note { display: flex; align-items: center; gap: 0.5rem; margin: 1.25rem 0 0; padding: 0.75rem 1rem; background: var(--site-hover); border-radius: 8px; font-size: 0.8125rem; color: var(--site-text-muted); }
  .privacy-note svg { width: 1rem; height: 1rem; flex-shrink: 0; color: var(--site-accent); }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .tool-widget { padding: 1.125rem; }
    .drop-zone { padding: 2rem 1rem; }
    .result-actions { grid-template-columns: 1fr; }
  }
</style>
